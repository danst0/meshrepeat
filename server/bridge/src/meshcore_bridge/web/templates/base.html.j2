<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}MeshCore Spiegel{% endblock %}</title>
  <link rel="stylesheet" href="/static/app.css?v={{ asset_version }}">
  {% block head_extra %}{% endblock %}
</head>
<body>
  <header>
    <div class="brand"><a href="/">MeshCore Spiegel</a></div>
    <nav>
      {% if user %}
        <span class="muted">{{ user.email }}{% if user.role == 'admin' %} (admin){% endif %}</span>
        <a href="/dashboard">Dashboard</a>
        <a href="/repeaters">Repeater</a>
        <a href="/companion/">Companion</a>
        {% if user.role == 'admin' %}<a href="/admin/">Admin</a>{% endif %}
        <form method="post" action="/logout" style="display:inline">
          <button type="submit" style="margin:0; padding:0.3rem 0.7rem;">Logout</button>
        </form>
      {% else %}
        <a href="/login">Login</a>
        <a href="/signup">Registrieren</a>
      {% endif %}
    </nav>
  </header>
  <main>
    {% if flash %}
      <div class="flash {{ flash.kind }}">{{ flash.message }}</div>
    {% endif %}
    {% block content %}{% endblock %}
  </main>
</body>
</html>
