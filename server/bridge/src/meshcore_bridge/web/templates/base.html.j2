<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}MeshCore Spiegel{% endblock %}</title>
  <style>
    :root {
      --bg: #0f1419;
      --fg: #d6deeb;
      --muted: #5f7e97;
      --accent: #82aaff;
      --danger: #ff5874;
      --ok: #addb67;
      --border: #1d2733;
      --card: #161e2c;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: ui-monospace, "Cascadia Code", Menlo, Consolas, monospace;
      background: var(--bg); color: var(--fg);
      line-height: 1.5;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    header {
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header .brand { font-weight: bold; }
    header nav a { margin-left: 1rem; }
    main { padding: 2rem; max-width: 960px; margin: 0 auto; }
    h1, h2 { color: var(--accent); }
    label { display: block; margin-top: 1rem; font-size: 0.9rem; color: var(--muted); }
    input, select, textarea {
      width: 100%;
      padding: 0.55rem;
      background: var(--card);
      color: var(--fg);
      border: 1px solid var(--border);
      border-radius: 4px;
      font-family: inherit;
    }
    button, input[type=submit] {
      margin-top: 1rem;
      padding: 0.6rem 1.2rem;
      background: var(--accent);
      color: var(--bg);
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
    }
    button:hover, input[type=submit]:hover { opacity: 0.9; }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.2rem;
      margin-bottom: 1rem;
    }
    .flash {
      padding: 0.7rem 1rem;
      margin-bottom: 1rem;
      border-radius: 4px;
      border: 1px solid var(--border);
    }
    .flash.error { color: var(--danger); border-color: var(--danger); }
    .flash.ok    { color: var(--ok);     border-color: var(--ok); }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.6rem; border-bottom: 1px solid var(--border); text-align: left; }
    code, pre {
      background: #0a0e14;
      padding: 0.2rem 0.4rem;
      border-radius: 3px;
      font-size: 0.9rem;
    }
    .token {
      word-break: break-all;
      display: inline-block;
      padding: 0.5rem 0.7rem;
      background: #0a0e14;
      border: 1px dashed var(--accent);
      border-radius: 4px;
    }
    .scope-public  { color: var(--accent); }
    .scope-pool    { color: var(--ok); }

    /* Tabs */
    .tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1rem;
    }
    .tab-btn {
      margin: 0;
      padding: 0.55rem 1.1rem;
      background: transparent;
      color: var(--muted);
      border: none;
      border-bottom: 2px solid transparent;
      border-radius: 0;
      cursor: pointer;
      font-weight: normal;
      font-family: inherit;
    }
    .tab-btn:hover { color: var(--fg); opacity: 1; }
    .tab-btn.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
      font-weight: bold;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Messenger layout */
    .messenger {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 1rem;
      min-height: 420px;
    }
    @media (max-width: 720px) {
      .messenger { grid-template-columns: 1fr; }
    }
    .thread-list {
      border-right: 1px solid var(--border);
      padding-right: .5rem;
      max-height: 480px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: .25rem;
    }
    .thread-item {
      margin: 0;
      padding: .45rem .55rem;
      background: transparent;
      color: var(--fg);
      border: 1px solid transparent;
      border-radius: 4px;
      text-align: left;
      cursor: pointer;
      font-family: inherit;
      font-weight: normal;
      border-left: 3px solid transparent;
    }
    .thread-item:hover { background: rgba(130,170,255,.08); }
    .thread-item.active {
      background: rgba(130,170,255,.12);
      border-left-color: var(--accent);
    }
    .thread-top {
      display: flex;
      justify-content: space-between;
      gap: .4rem;
      font-size: .92rem;
    }
    .thread-time { color: var(--muted); font-size: .8rem; }
    .thread-snip {
      color: var(--muted);
      font-size: .8rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .thread-view { display: flex; flex-direction: column; min-width: 0; }
    .thread-header {
      padding: .4rem 0 .6rem;
      border-bottom: 1px solid var(--border);
      color: var(--accent);
      font-weight: bold;
    }
    .message-list {
      flex: 1;
      overflow-y: auto;
      padding: .6rem 0;
      max-height: 400px;
      display: flex;
      flex-direction: column;
      gap: .4rem;
    }
    .message {
      max-width: 80%;
      padding: .4rem .6rem;
      border-radius: 6px;
      background: rgba(255,255,255,.03);
      border: 1px solid var(--border);
    }
    .message.in  { align-self: flex-start; }
    .message.out {
      align-self: flex-end;
      background: rgba(130,170,255,.10);
      border-color: rgba(130,170,255,.30);
    }
    .msg-meta { font-size: .75rem; color: var(--muted); margin-bottom: .15rem; }
    .msg-text { white-space: pre-wrap; word-break: break-word; }
    .compose-row {
      display: flex;
      gap: .5rem;
      padding-top: .5rem;
      border-top: 1px solid var(--border);
    }
    .compose-row input { flex: 1; margin: 0; }
    .compose-row button { margin: 0; }
    .at-input-wrap { position: relative; flex: 1; }
    .at-input-wrap input { width: 100%; }
    .at-popup {
      position: absolute;
      bottom: calc(100% + .25rem);
      left: 0;
      right: 0;
      max-height: 220px;
      overflow-y: auto;
      background: var(--card);
      border: 1px solid var(--accent);
      border-radius: 4px;
      box-shadow: 0 4px 12px rgba(0,0,0,.4);
      z-index: 50;
    }
    .at-item {
      display: flex;
      justify-content: space-between;
      gap: .5rem;
      padding: .35rem .55rem;
      cursor: pointer;
      font-size: .9rem;
    }
    .at-item:hover, .at-item.active {
      background: rgba(130,170,255,.18);
    }
    .at-name { color: var(--fg); }
    .at-sub { color: var(--muted); font-size: .75rem; }
  </style>
</head>
<body>
  <header>
    <div class="brand"><a href="/">MeshCore Spiegel</a></div>
    <nav>
      {% if user %}
        <span class="muted">{{ user.email }}{% if user.role == 'admin' %} (admin){% endif %}</span>
        <a href="/dashboard">Dashboard</a>
        <a href="/repeaters">Repeater</a>
        <a href="/companion/">Companion</a>
        {% if user.role == 'admin' %}<a href="/admin/">Admin</a>{% endif %}
        <form method="post" action="/logout" style="display:inline">
          <button type="submit" style="margin:0; padding:0.3rem 0.7rem;">Logout</button>
        </form>
      {% else %}
        <a href="/login">Login</a>
        <a href="/signup">Registrieren</a>
      {% endif %}
    </nav>
  </header>
  <main>
    {% if flash %}
      <div class="flash {{ flash.kind }}">{{ flash.message }}</div>
    {% endif %}
    {% block content %}{% endblock %}
  </main>
</body>
</html>
