{% extends "base.html.j2" %}
{% block title %}Repeater-Wichtigkeit — MeshCore Spiegel{% endblock %}
{% block head_extra %}
<style>
  /* Toolbar: Filter, Sort, Reload */
  .rep-toolbar {
    display: flex; flex-wrap: wrap; gap: .8rem; align-items: end;
  }
  .rep-toolbar > div { display: flex; flex-direction: column; gap: .2rem; }
  .rep-toolbar label { margin: 0; font-size: .8rem; }
  .rep-toolbar select, .rep-toolbar button {
    padding: .45rem .6rem; min-height: 40px;
  }
  .rep-toolbar .btn-dir {
    width: 40px; padding: 0; min-width: 40px;
  }

  .rep-summary { font-size: 1.05rem; margin: .8rem 0 0; }
  .rep-summary strong { color: var(--accent); }
  .rep-summary .muted {
    color: var(--muted); margin-left: .6rem; font-size: .85rem;
  }
  .rep-banner {
    background: rgba(255,200,90,.10);
    border-left: 3px solid rgba(255,200,90,.6);
    padding: .55rem .8rem; margin: .8rem 0 0;
    font-size: .85rem; color: var(--muted);
    border-radius: 3px;
  }
  .rep-stat { color: var(--muted); font-size: .85rem; }

  /* Liste der Karten */
  .rep-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr; gap: .55rem;
  }
  .rep-card { padding: 0; }
  .rep-card-btn {
    /* Button auf Card-Oberfläche → 100% Hitbox, A11Y, kein <tr>-Click */
    display: grid;
    grid-template-columns: 1fr;
    gap: .55rem;
    width: 100%;
    margin: 0; padding: .85rem 1rem;
    background: var(--card);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-align: left;
    font-family: inherit; font-weight: normal; font-size: 1rem;
    cursor: pointer;
    min-height: 44px;
    transition: border-color .12s, background .12s;
  }
  .rep-card-btn:hover,
  .rep-card-btn:focus-visible {
    border-color: rgba(130,170,255,.45);
    background: rgba(130,170,255,.04);
    outline: none;
  }

  .rep-name {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: .15rem .6rem; min-width: 0;
  }
  .rep-name strong { font-size: 1rem; color: var(--fg); }
  .rep-name .pkkey {
    font-family: ui-monospace, monospace; color: var(--muted);
    font-size: .78rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    max-width: 100%;
  }

  .rep-score {
    display: flex; align-items: center; gap: .6rem;
  }
  .rep-score-val {
    font-size: 1.35rem; font-weight: bold; color: var(--accent);
    font-variant-numeric: tabular-nums;
    min-width: 3.2rem;
  }
  .rep-score .rep-bar-svg { flex: 1; min-width: 80px; max-width: 220px; }

  .rep-subs {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: .5rem .9rem;
    margin: 0;
  }
  .rep-sub { margin: 0; min-width: 0; }
  .rep-sub dt {
    font-size: .68rem; text-transform: uppercase; letter-spacing: .06em;
    color: var(--muted); margin: 0 0 .15rem;
  }
  .rep-sub dd {
    margin: 0; display: flex; align-items: center; gap: .4rem;
    font-size: .82rem; color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .rep-sub dd .rep-bar-svg { flex: 1; min-width: 0; max-width: 110px; }
  .rep-sub-val { white-space: nowrap; }

  .rep-foot {
    display: flex; flex-wrap: wrap; gap: .15rem .6rem;
    color: var(--muted); font-size: .8rem;
    border-top: 1px dashed rgba(130,170,255,.10);
    padding-top: .45rem;
  }
  .rep-foot .sep { opacity: .5; }
  .rep-foot strong { color: var(--fg); font-weight: normal; }

  .rep-bar-svg { display: block; width: 100%; height: 8px; }
  .rep-bar-svg rect.b-track { fill: rgba(130,170,255,.08); }
  .rep-bar-svg rect.b-total  { fill: rgba(255,200,90,.65); }
  .rep-bar-svg rect.b-fwd    { fill: rgba(120,210,140,.65); }
  .rep-bar-svg rect.b-bottle { fill: rgba(255,88,116,.65); }
  .rep-bar-svg rect.b-reach  { fill: rgba(130,170,255,.70); }
  .rep-bar-svg rect.b-life   { fill: rgba(200,160,255,.65); }

  .rep-empty {
    color: var(--muted); padding: 2rem 1rem; text-align: center;
    font-size: .9rem;
  }

  /* Spalten-Header (nur Desktop) — visuell wie eine Tabellen-Headerzeile */
  .rep-list-head { display: none; }

  /* Modal */
  .rep-modal-bg {
    position: fixed; inset: 0; background: rgba(0,0,0,.6);
    display: none; align-items: center; justify-content: center; z-index: 100;
    padding: 1rem;
  }
  .rep-modal-bg.open { display: flex; }
  .rep-modal {
    background: var(--card);
    border: 1px solid rgba(130,170,255,.25);
    border-radius: 6px; padding: 1.2rem;
    max-width: 640px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    box-shadow: 0 8px 32px rgba(0,0,0,.5);
    position: relative;
  }
  .rep-modal h3 { margin: 0 2rem .8rem 0; color: var(--accent); font-size: 1.1rem; }
  .rep-modal dl {
    display: grid; grid-template-columns: max-content 1fr;
    gap: .35rem .9rem; font-size: .9rem; margin: 0;
  }
  .rep-modal dt { color: var(--muted); }
  .rep-modal dd { margin: 0; word-break: break-word; }
  .rep-modal .pkkey {
    font-family: ui-monospace, monospace; font-size: .8rem;
    word-break: break-all;
  }
  .rep-modal .close {
    position: absolute; top: .5rem; right: .6rem;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--muted);
    background: transparent; border: 1px solid transparent;
    border-radius: 4px; font-size: 1.1rem;
  }
  .rep-modal .close:hover {
    color: var(--fg); border-color: var(--border);
  }

  /* ---------- Desktop ab 760px ---------- */
  @media (min-width: 760px) {
    .rep-list { gap: .35rem; }
    .rep-card-btn {
      grid-template-columns:
        minmax(180px, 1.5fr)   /* Name */
        minmax(140px, .9fr)    /* Score + Bar */
        minmax(320px, 2.4fr)   /* 4 Sub-Scores */
        minmax(140px, .9fr);   /* Adverts + Last seen */
      align-items: center;
      gap: 1rem;
      padding: .65rem 1rem;
    }
    .rep-name { flex-direction: column; align-items: flex-start; gap: .1rem; }
    .rep-name .pkkey { font-size: .72rem; }
    .rep-subs {
      grid-template-columns: repeat(4, 1fr);
      gap: 0 .8rem;
    }
    .rep-foot {
      flex-direction: column; gap: .1rem;
      border-top: none; padding-top: 0; align-items: flex-end;
      text-align: right;
    }
    .rep-foot .sep { display: none; }

    /* Header-Zeile in Tabellen-Optik */
    .rep-list-head {
      display: grid;
      grid-template-columns:
        minmax(180px, 1.5fr)
        minmax(140px, .9fr)
        minmax(320px, 2.4fr)
        minmax(140px, .9fr);
      gap: 1rem;
      padding: .25rem 1rem;
      font-size: .72rem;
      text-transform: uppercase; letter-spacing: .06em;
      color: var(--muted);
    }
    .rep-list-head .head-subs {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 0 .8rem;
    }
    .rep-list-head .head-foot { text-align: right; }
    /* Auf Desktop sind die Sub-Labels in der Header-Zeile, in den Cards
       weg → ruhigere Optik */
    .rep-card-btn .rep-sub dt { display: none; }
    .rep-card-btn .rep-sub dd { padding-top: .15rem; }
  }

  /* ---------- Phone ≤460px ---------- */
  @media (max-width: 460px) {
    .rep-modal-bg { padding: 0; align-items: stretch; }
    .rep-modal {
      max-height: 100vh; max-width: 100%;
      border-radius: 0; border: none;
    }
    .rep-toolbar { gap: .55rem; }
    .rep-toolbar > div { flex: 1 1 8rem; }
    .rep-card-btn { padding: .8rem .85rem; }
  }
</style>
{% endblock %}
{% block content %}
  <h1>Repeater-Wichtigkeit</h1>
  <p>Bewertung pro Repeater-Pubkey, abgeleitet aus den persistierten LoRa-Paketen.
     Vier Sub-Scores: <em>Forwarding</em> (Hops in <code>path_hashes</code>),
     <em>Bottleneck</em> (Repeater liegt in jedem distinkten Pfad eines Origins),
     <em>Reach</em> (über wie viele unterschiedliche ADVERT-Origins er gesehen wurde),
     <em>Liveness</em> (Decay über last_seen).</p>

  <div class="card">
    <form id="filters" class="rep-toolbar" onsubmit="return false">
      <div>
        <label for="f-window">Zeitraum</label>
        <select id="f-window">
          <option value="24h">letzte 24 h</option>
          <option value="7d" selected>letzte 7 d</option>
          <option value="30d">letzte 30 d</option>
        </select>
      </div>
      <div>
        <label for="f-sort">Sortieren nach</label>
        <select id="f-sort">
          <option value="total" selected>Score (gesamt)</option>
          <option value="fwd">Forwarding</option>
          <option value="bottle">Bottleneck</option>
          <option value="reach">Reach</option>
          <option value="life">Liveness</option>
          <option value="adv">Adverts</option>
          <option value="last">Last seen</option>
          <option value="name">Name</option>
        </select>
      </div>
      <div>
        <label for="btn-dir">Reihenfolge</label>
        <button type="button" id="btn-dir" class="btn-dir" title="Sortier-Richtung">▼</button>
      </div>
      <div>
        <label>&nbsp;</label>
        <button type="button" id="btn-reload">Neu laden</button>
      </div>
      <div>
        <label>&nbsp;</label>
        <span id="stat" class="rep-stat"></span>
      </div>
    </form>
    <div class="rep-summary" id="summary">—</div>
    <div class="rep-banner" id="banner-trunc" style="display:none">
      Hinweis: Forwarding/Reach/Bottleneck sind durch die 7-Tage-Retention der
      Paket-Tabelle gekappt. Liveness und Advert-Count nutzen das volle Fenster.
    </div>
  </div>

  <div class="rep-list-head" aria-hidden="true">
    <div>Name</div>
    <div>Score</div>
    <div class="head-subs">
      <div>Forwarding</div>
      <div>Bottleneck</div>
      <div>Reach</div>
      <div>Liveness</div>
    </div>
    <div class="head-foot">Adverts · Last seen</div>
  </div>

  <ul class="rep-list" id="rep-rows">
    <li class="rep-empty">—</li>
  </ul>

  <div class="rep-modal-bg" id="modal-bg" role="dialog" aria-modal="true" aria-labelledby="modal-name">
    <div class="rep-modal" id="modal">
      <button type="button" class="close" id="modal-close" aria-label="Schließen">✕</button>
      <h3 id="modal-name">—</h3>
      <dl id="modal-body"></dl>
    </div>
  </div>

<script>
const elWindow = document.getElementById('f-window');
const elSort   = document.getElementById('f-sort');
const elDir    = document.getElementById('btn-dir');
const elStat   = document.getElementById('stat');
const elSummary = document.getElementById('summary');
const elBanner = document.getElementById('banner-trunc');
const elRows   = document.getElementById('rep-rows');
const elModalBg   = document.getElementById('modal-bg');
const elModal     = document.getElementById('modal');
const elModalName = document.getElementById('modal-name');
const elModalBody = document.getElementById('modal-body');

let lastData = null;
let sortKey = 'total';
let sortDir = 'desc';

function fmtNum(n) { return Number(n).toLocaleString('de-DE'); }
function fmtPct(n) { return (n * 100).toFixed(1) + '%'; }
function fmtScore(n) { return n.toFixed(3); }
function escape(s) {
  return String(s == null ? '' : s).replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
}
function fmtRel(iso) {
  if (!iso) return '—';
  const t = new Date(iso);
  const dh = (Date.now() - t.getTime()) / 3600000;
  if (dh < 1) return Math.round(dh * 60) + ' min';
  if (dh < 24) return dh.toFixed(1) + ' h';
  return (dh / 24).toFixed(1) + ' d';
}

function bar(value, cls) {
  const pct = Math.max(0, Math.min(1, Number(value) || 0));
  const w = (pct * 100).toFixed(1);
  return '<svg class="rep-bar-svg" viewBox="0 0 100 8" preserveAspectRatio="none" aria-hidden="true">'
    + '<rect class="b-track" x="0" y="1" width="100" height="6" rx="2"></rect>'
    + (pct > 0 ? '<rect class="' + cls + '" x="0" y="1" width="' + w + '" height="6" rx="2"></rect>' : '')
    + '</svg>';
}

const SORT_ACCESSORS = {
  name:   r => (r.name || '').toLowerCase(),
  total:  r => r.total_score,
  fwd:    r => r.forwarding_score,
  bottle: r => r.bottleneck_score,
  reach:  r => r.reach_score,
  life:   r => r.liveness_score,
  adv:    r => r.advert_count,
  last:   r => r.last_seen_at || '',
};

function sortRows(rows) {
  const acc = SORT_ACCESSORS[sortKey] || SORT_ACCESSORS.total;
  const sign = sortDir === 'asc' ? 1 : -1;
  return rows.slice().sort((a, b) => {
    const va = acc(a), vb = acc(b);
    if (va < vb) return -1 * sign;
    if (va > vb) return  1 * sign;
    return 0;
  });
}

function subCell(label, barCls, value, valueText) {
  return '<div class="rep-sub">'
    + '<dt>' + label + '</dt>'
    + '<dd>' + bar(value, barCls)
    + (valueText != null ? '<span class="rep-sub-val">' + valueText + '</span>' : '')
    + '</dd></div>';
}

function render() {
  if (!lastData) return;
  const rows = sortRows(lastData.repeaters);
  if (!rows.length) {
    elRows.innerHTML = '<li class="rep-empty">keine Repeater bekannt</li>';
    return;
  }
  elRows.innerHTML = rows.map((r, i) => {
    const short = r.pubkey_short || (r.pubkey_hex || '').slice(0, 12);
    return '<li class="rep-card">'
      + '<button type="button" class="rep-card-btn" data-idx="' + i + '">'
      +   '<header class="rep-name">'
      +     '<strong>' + escape(r.name || '?') + '</strong>'
      +     '<span class="pkkey">' + escape(short) + '…</span>'
      +   '</header>'
      +   '<div class="rep-score">'
      +     '<span class="rep-score-val">' + fmtScore(r.total_score) + '</span>'
      +     bar(r.total_score, 'b-total')
      +   '</div>'
      +   '<dl class="rep-subs">'
      +     subCell('Forwarding', 'b-fwd',    r.forwarding_score, fmtPct(r.forward_share))
      +     subCell('Bottleneck', 'b-bottle', r.bottleneck_score, fmtNum(r.bottleneck_origins))
      +     subCell('Reach',      'b-reach',  r.reach_score,      fmtNum(r.reach_endpoints))
      +     subCell('Liveness',   'b-life',   r.liveness_score,   null)
      +   '</dl>'
      +   '<footer class="rep-foot">'
      +     '<span><strong>' + fmtNum(r.advert_count) + '</strong> Adverts</span>'
      +     '<span class="sep">·</span>'
      +     '<span>' + fmtRel(r.last_seen_at) + '</span>'
      +   '</footer>'
      + '</button>'
      + '</li>';
  }).join('');
  elRows.querySelectorAll('.rep-card-btn').forEach(btn => {
    btn.addEventListener('click', () => openModal(parseInt(btn.dataset.idx, 10)));
  });
}

function openModal(idx) {
  const rows = sortRows(lastData.repeaters);
  const r = rows[idx];
  if (!r) return;
  elModalName.textContent = r.name || '?';
  elModalBody.innerHTML =
    '<dt>Pubkey</dt><dd class="pkkey">' + escape(r.pubkey_hex) + '</dd>'
    + '<dt>Total-Score</dt><dd>' + fmtScore(r.total_score) + '</dd>'
    + '<dt>Forwarding</dt><dd>' + fmtScore(r.forwarding_score)
      + ' (' + fmtNum(r.forward_count.toFixed(1)) + ' Hops, ' + fmtPct(r.forward_share) + ' aller Pakete)</dd>'
    + '<dt>Unique paths</dt><dd>' + fmtNum(r.unique_paths) + '</dd>'
    + '<dt>Bottleneck</dt><dd>' + fmtScore(r.bottleneck_score)
      + ' (Origin-Count ' + fmtNum(r.bottleneck_origins) + ')</dd>'
    + '<dt>Reach</dt><dd>' + fmtScore(r.reach_score)
      + ' (' + fmtNum(r.reach_endpoints) + ' verschiedene Origins)</dd>'
    + '<dt>Liveness</dt><dd>' + fmtScore(r.liveness_score)
      + ' (last_seen ' + fmtRel(r.last_seen_at) + ')</dd>'
    + '<dt>Advert-Count</dt><dd>' + fmtNum(r.advert_count) + '</dd>'
    + (r.last_lat != null && r.last_lon != null
        ? '<dt>Position</dt><dd>' + r.last_lat.toFixed(5) + ', ' + r.last_lon.toFixed(5) + '</dd>' : '');
  elModalBg.classList.add('open');
}

function closeModal() { elModalBg.classList.remove('open'); }
elModalBg.addEventListener('click', e => {
  if (e.target === elModalBg) closeModal();
});
document.getElementById('modal-close').addEventListener('click', closeModal);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && elModalBg.classList.contains('open')) closeModal();
});

function updateDirBtn() {
  elDir.textContent = sortDir === 'asc' ? '▲' : '▼';
  elDir.title = sortDir === 'asc' ? 'aufsteigend' : 'absteigend';
}

elSort.addEventListener('change', () => {
  const k = elSort.value;
  if (k !== sortKey) {
    sortKey = k;
    sortDir = (k === 'name' || k === 'last') ? 'asc' : 'desc';
    updateDirBtn();
  }
  render();
});
elDir.addEventListener('click', () => {
  sortDir = (sortDir === 'asc' ? 'desc' : 'asc');
  updateDirBtn();
  render();
});

async function refresh() {
  elStat.textContent = 'lade …';
  try {
    const r = await fetch('/api/v1/admin/repeaters/metrics?window=' + elWindow.value, {credentials:'same-origin'});
    if (!r.ok) { elStat.textContent = 'fetch ' + r.status; return; }
    lastData = await r.json();
    elSummary.innerHTML =
      '<strong>' + fmtNum(lastData.repeater_count) + '</strong> Repeater bekannt · '
      + '<strong>' + fmtNum(lastData.total_packets) + '</strong> Pakete im Fenster'
      + '<span class="muted">Fenster: ' + escape(lastData.window) + ' — seit ' + escape(lastData.cutoff) + '</span>';
    elBanner.style.display = lastData.forward_truncated_to_7d ? '' : 'none';
    render();
    elStat.textContent = '';
  } catch (e) {
    elStat.textContent = 'fetch-fail: ' + e;
  }
}

elWindow.addEventListener('change', refresh);
document.getElementById('btn-reload').addEventListener('click', refresh);
updateDirBtn();
refresh();
</script>
{% endblock %}
