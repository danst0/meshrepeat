{% extends "base.html.j2" %}
{% block title %}Companion — MeshCore Spiegel{% endblock %}
{% block content %}
  <h1>Companion-Identitäten</h1>
  <p>Virtuelle MeshCore-Teilnehmer, die der Server für dich betreibt.
     Jede Identität wirkt im gewählten Scope (public oder Private-Pool)
     und kann DMs an Mesh-Peers senden/empfangen sowie an Kanäle posten.</p>

  <div class="card">
    <h2>Deine Identitäten ({{ identities | length }})</h2>
    {% if identities %}
      <table>
        <thead><tr><th>Name</th><th>Scope</th><th>Pubkey</th><th></th></tr></thead>
        <tbody>
        {% for i in identities %}
          <tr>
            <td>{{ i.name }}</td>
            <td class="scope-{{ 'public' if i.scope == 'public' else 'pool' }}">{{ i.scope }}</td>
            <td><code>{{ i.pubkey.hex()[:24] }}…</code></td>
            <td>
              <a href="/companion/{{ i.id }}/"
                 style="display:inline-block;padding:.3rem .7rem;background:var(--accent);
                        color:var(--bg);border-radius:4px;font-weight:bold;text-decoration:none">
                öffnen →
              </a>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>Noch keine Identitäten.</p>
    {% endif %}
  </div>

  <div class="card">
    <h2>Neue Identität</h2>
    <form method="post" action="/companion/identities">
      <label>Name
        <input name="name" required maxlength="64">
      </label>
      <label>Scope
        <select name="scope">
          <option value="public">public</option>
          <option value="pool:new">pool:new — neuen privaten Pool</option>
        </select>
      </label>
      <label><input type="checkbox" name="is_echo" value="true"> Echo-Bot (DM-Replies mit Metadaten)</label>
      <button type="submit">Anlegen</button>
    </form>
  </div>
{% endblock %}
