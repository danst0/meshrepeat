{% extends "base.html.j2" %}
{% block title %}{{ identity.name }} — Companion{% endblock %}
{% block head_extra %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}
{% block content %}
  <p style="margin:0 0 .5rem"><a href="/companion/">← Companion-Übersicht</a></p>

  <div class="card" style="margin-bottom:1rem">
    <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem">
      <div>
        <h1 id="ident-name" style="margin:0">{{ identity.name }}</h1>
        <span class="scope-{{ 'public' if identity.scope == 'public' else 'pool' }}">{{ identity.scope }}</span>
        · <code title="{{ identity.pubkey.hex() }}">{{ identity.pubkey.hex()[:16] }}…</code>
      </div>
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn" data-tab="chats">Chats</button>
    <button class="tab-btn" data-tab="map">Karte</button>
    <button class="tab-btn" data-tab="settings">Settings</button>
  </div>

  {# ---------- Chats (DMs + Channels unified) ---------- #}
  <section class="tab-panel" data-tab="chats">
    <div class="card messenger">
      <aside class="thread-list" id="threads">
        <form id="dm-new" class="thread-new">
          <div class="at-input-wrap">
            <input id="dm-new-peer" required maxlength="128" autocomplete="off"
                   placeholder="Name tippen oder Pubkey-Hex einfügen…">
            <div class="at-popup" id="dm-new-popup" hidden></div>
          </div>
        </form>
        <div class="thread-section-label">Kanäle</div>
        <div id="ch-list">
          <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
        </div>
        <div class="thread-section-label">DMs</div>
        <div id="dm-list">
          <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
        </div>
      </aside>
      <div class="thread-view">
        <div id="conv-header" class="thread-header">Wähle einen Chat oder starte einen DM.</div>
        <div id="conv-messages" class="message-list"></div>
        <form id="conv-compose" class="compose-row" style="display:none">
          <div class="at-input-wrap">
            <input id="conv-text" required autocomplete="off"
                   placeholder="Nachricht… (@ für Auto-Complete)">
            <div class="at-popup" id="conv-at-popup" hidden></div>
          </div>
          <button type="submit">Senden</button>
        </form>
      </div>
    </div>
  </section>

  {# ---------- Map ---------- #}
  <section class="tab-panel" data-tab="map">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
        <h2 style="margin:0">Karte beobachteter Knoten</h2>
        <span id="map-status" style="color:var(--muted);font-size:.85em"></span>
      </div>
      <div id="node-map" class="node-map"></div>
      <p style="margin-top:.5rem;font-size:.85em;color:var(--muted)">
        Pins entstehen aus Lat/Lon in ADVERTs ODER aus
        REQ_TYPE_GET_TELEMETRY_DATA (LPP_GPS) — anfragebar pro Kontakt
        unten. Knoten mit unset-Koordinaten (0,0) werden ignoriert.
      </p>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Kontakte — Telemetrie anfragen</h3>
      <p style="font-size:.85em;color:var(--muted);margin-top:0">
        REQ-Paket via LoRa an den Peer; Antwort kommt asynchron, Karte
        aktualisiert sich nach 5 s Polling. Kostet Mesh-Bandbreite —
        sparsam einsetzen.
      </p>
      <div id="telemetry-status" style="color:var(--muted);font-size:.85em;margin-bottom:.5rem"></div>
      <div id="telemetry-list" class="telemetry-list">
        <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
      </div>
    </div>
  </section>

  {# ---------- Settings ---------- #}
  <section class="tab-panel" data-tab="settings">
    <div class="card">
      <h2>Identität</h2>
      <form method="post" action="/companion/{{ identity.id }}/rename">
        <label>Name
          <input name="name" required maxlength="64" value="{{ identity.name }}">
        </label>
        <button type="submit">Umbenennen</button>
      </form>
      <p style="margin-top:1rem;font-size:.9em;color:var(--muted)">
        Pubkey: <code>{{ identity.pubkey.hex() }}</code><br>
        Scope: <code>{{ identity.scope }}</code><br>
        Created: {{ identity.created_at | localtime }}
      </p>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
        <form method="post" action="/companion/{{ identity.id }}/advert" style="margin:0">
          <button type="submit" style="margin:0">Advert jetzt senden</button>
        </form>
        <form method="post" action="/companion/{{ identity.id }}/archive" style="margin:0"
              onsubmit="return confirm('Identität archivieren? Sie verschwindet aus der Liste und sendet keine Adverts mehr.');">
          <button type="submit" style="margin:0;background:var(--danger)">archivieren</button>
        </form>
      </div>
    </div>

    <div class="card">
      <h2>Kanäle ({{ channels | length }})</h2>
      {% if channels %}
        <table>
          <thead><tr><th>Name</th><th>Hash</th><th></th></tr></thead>
          <tbody>
          {% for ch in channels %}
            <tr>
              <td>{{ ch.name }}</td>
              <td><code>{{ ch.channel_hash.hex() }}</code></td>
              <td>
                <form method="post" action="/companion/channels/{{ ch.id }}/delete"
                      style="margin:0"
                      onsubmit="return confirm('Kanal {{ ch.name }} löschen?');">
                  <button type="submit"
                          style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                    löschen
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p>Noch keine Kanäle.</p>
      {% endif %}

      <h3 style="margin-top:1rem">Kanal hinzufügen</h3>
      <form method="post" action="/companion/{{ identity.id }}/channels">
        <label>Name
          <input name="name" required maxlength="64" placeholder="z.B. tech">
        </label>
        <label>Passwort
          <input name="password" required maxlength="128"
                 placeholder="geteiltes Channel-Passwort">
        </label>
        <button type="submit">Hinzufügen</button>
      </form>
      <p style="font-size:.85em;color:var(--muted)">
        Secret = <code>sha256(name + ":" + password)[:32]</code>. Alle
        Teilnehmer brauchen denselben Namen und dasselbe Passwort.
      </p>
    </div>
  </section>

<script>
(() => {
  const IDENTITY_ID = "{{ identity.id }}";
  const IDENTITY_NAME = {{ identity.name | tojson }};
  const API = "/api/v1/companion";
  const POLL_ACTIVE_MS = 5000;
  const POLL_THREADS_MS = 15000;
  const AT_TARGETS = {{ at_targets | tojson }};
  const LS_KEY = `meshcore.companion.${IDENTITY_ID}.lastConv`;
  const LS_TAB = `meshcore.companion.${IDENTITY_ID}.lastTab`;

  // ---------- Hash + LocalStorage state ----------
  function parseHash() {
    const out = {};
    const h = (location.hash || "").replace(/^#/, "");
    for (const kv of h.split("&")) {
      const [k, v] = kv.split("=");
      if (k) out[k] = decodeURIComponent(v || "");
    }
    return out;
  }
  function writeHash(s) {
    const enc = Object.entries(s).map(([k,v]) => k+"="+encodeURIComponent(v)).join("&");
    history.replaceState(null, "", "#"+enc);
  }
  function patchHash(p) { writeHash({...parseHash(), ...p}); }
  function persistConv(spec) {
    try { localStorage.setItem(LS_KEY, spec || ""); } catch (e) {}
  }
  function persistTab(name) {
    try { localStorage.setItem(LS_TAB, name); } catch (e) {}
  }
  function restoredConv() {
    try { return localStorage.getItem(LS_KEY) || ""; } catch (e) { return ""; }
  }
  function restoredTab() {
    try { return localStorage.getItem(LS_TAB) || ""; } catch (e) { return ""; }
  }

  // ---------- Tabs ----------
  const tabBtns = document.querySelectorAll(".tab-btn");
  const tabPanels = document.querySelectorAll(".tab-panel");
  function showTab(name) {
    tabBtns.forEach(b => b.classList.toggle("active", b.dataset.tab === name));
    tabPanels.forEach(p => p.classList.toggle("active", p.dataset.tab === name));
  }
  tabBtns.forEach(b => b.addEventListener("click", () => {
    patchHash({tab: b.dataset.tab});
    persistTab(b.dataset.tab);
    showTab(b.dataset.tab);
    if (b.dataset.tab === "chats") loadThreads();
    else if (b.dataset.tab === "map") ensureMap();
  }));

  // ---------- State ----------
  let active = null;  // {kind:"dm"|"channel", peer?, peer_name?, channel_id?, channel_name?}
  let activeTimer = null;
  let lastActiveTs = null;
  let threadCache = {dms: [], channels: []};

  function fmtTime(iso) {
    if (!iso) return "";
    const d = new Date(iso);
    return d.toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"});
  }
  function fmtDate(iso) {
    if (!iso) return "";
    const d = new Date(iso);
    return d.toLocaleDateString() + " " + fmtTime(iso);
  }
  function shortHex(hex, n=8) { return hex ? hex.slice(0,n)+"…" : ""; }
  function escText(s) { const d = document.createElement("div"); d.textContent = s ?? ""; return d.innerHTML; }

  // ---------- Threads ----------
  async function loadThreads() {
    try {
      const r = await fetch(`${API}/identities/${IDENTITY_ID}/threads`, {credentials:"same-origin"});
      if (!r.ok) return;
      const j = await r.json();
      threadCache = {dms: j.dms || [], channels: j.channels || []};
      renderChannelList(threadCache.channels);
      renderDmList(threadCache.dms);
      // Falls active mit unbekanntem Namen geladen wurde, jetzt nachtragen
      if (active && active.kind === "channel" && (!active.channel_name || active.channel_name.length <= 8)) {
        const ch = threadCache.channels.find(c => c.id === active.channel_id);
        if (ch) {
          active.channel_name = ch.name;
          document.getElementById("conv-header").textContent = "#" + ch.name;
        }
      }
      if (active && active.kind === "dm" && !active.peer_name) {
        const dm = threadCache.dms.find(d => d.peer_pubkey_hex === active.peer);
        if (dm && dm.peer_name) {
          active.peer_name = dm.peer_name;
          document.getElementById("conv-header").textContent =
            dm.peer_name + " · " + shortHex(active.peer, 16);
        }
      }
    } catch (e) {
      console.warn("threads load failed", e);
    }
  }

  function renderChannelList(chs) {
    const box = document.getElementById("ch-list");
    if (!chs.length) {
      box.innerHTML = '<div class="thread-empty" style="color:var(--muted);padding:.5rem">Keine Kanäle.</div>';
      return;
    }
    box.innerHTML = "";
    for (const ch of chs) {
      const item = document.createElement("button");
      item.type = "button";
      item.className = "thread-item";
      if (active && active.kind === "channel" && active.channel_id === ch.id) item.classList.add("active");
      const last = ch.last_text ? escText(ch.last_text).slice(0,40) : '<span style="color:var(--muted)">—</span>';
      item.innerHTML = `<div class="thread-top">#${escText(ch.name)}<span class="thread-time">${fmtTime(ch.last_ts)}</span></div>
                        <div class="thread-snip">${last}</div>`;
      item.addEventListener("click", () => selectChannel(ch.id, ch.name));
      box.appendChild(item);
    }
  }

  function renderDmList(dms) {
    const box = document.getElementById("dm-list");
    if (!dms.length) {
      box.innerHTML = '<div class="thread-empty" style="color:var(--muted);padding:.5rem">Keine DMs. Starte oben einen neuen Thread.</div>';
      return;
    }
    box.innerHTML = "";
    for (const t of dms) {
      const item = document.createElement("button");
      item.type = "button";
      item.className = "thread-item";
      if (active && active.kind === "dm" && active.peer === t.peer_pubkey_hex) item.classList.add("active");
      const star = t.favorite ? '<span style="color:gold">★</span> ' : '';
      const peer = escText(t.peer_name || shortHex(t.peer_pubkey_hex, 12));
      const last = t.last_text ? escText(t.last_text).slice(0,40) : '<span style="color:var(--muted)">—</span>';
      item.innerHTML = `<div class="thread-top">${star}${peer}<span class="thread-time">${fmtTime(t.last_ts)}</span></div>
                        <div class="thread-snip">${last}</div>`;
      item.addEventListener("click", () => selectDm(t.peer_pubkey_hex, t.peer_name));
      box.appendChild(item);
    }
  }

  // ---------- Conv selection ----------
  async function selectDm(peerHex, peerName) {
    active = {kind:"dm", peer: peerHex, peer_name: peerName || null};
    lastActiveTs = null;
    const spec = "dm:" + peerHex;
    patchHash({tab:"chats", conv: spec});
    persistConv(spec);
    persistTab("chats");
    document.getElementById("conv-header").textContent =
      (peerName ? peerName+" · " : "") + shortHex(peerHex, 16);
    document.getElementById("conv-messages").innerHTML = "";
    setComposeMode("dm");
    await loadDmMessages(peerHex, true);
    armActiveTimer();
    markActiveThread();
  }

  async function selectChannel(channelId, channelName) {
    active = {kind:"channel", channel_id: channelId, channel_name: channelName};
    lastActiveTs = null;
    const spec = "ch:" + channelId;
    patchHash({tab:"chats", conv: spec});
    persistConv(spec);
    persistTab("chats");
    document.getElementById("conv-header").textContent = "#" + channelName;
    document.getElementById("conv-messages").innerHTML = "";
    setComposeMode("channel");
    await loadChannelMessages(channelId, true);
    armActiveTimer();
    markActiveThread();
  }

  function setComposeMode(kind) {
    const form = document.getElementById("conv-compose");
    const input = document.getElementById("conv-text");
    form.style.display = "flex";
    if (kind === "dm") {
      input.maxLength = 200;
      input.placeholder = "Nachricht… (@ für Auto-Complete)";
    } else {
      input.maxLength = 140;
      input.placeholder = `Wird mit '${IDENTITY_NAME}: ' präfixiert. @ für Auto-Complete.`;
    }
  }

  async function loadDmMessages(peerHex, replace) {
    const url = `${API}/identities/${IDENTITY_ID}/dms/${peerHex}` +
                (lastActiveTs && !replace ? `?since=${encodeURIComponent(lastActiveTs)}` : "");
    const r = await fetch(url, {credentials:"same-origin"});
    if (!r.ok) return;
    const list = await r.json();
    appendMessages(list, replace);
  }

  async function loadChannelMessages(channelId, replace) {
    const url = `${API}/identities/${IDENTITY_ID}/channels/${channelId}/messages` +
                (lastActiveTs && !replace ? `?since=${encodeURIComponent(lastActiveTs)}` : "");
    const r = await fetch(url, {credentials:"same-origin"});
    if (!r.ok) return;
    const list = await r.json();
    appendMessages(list, replace);
  }

  function fmtHops(n) {
    if (n == null) return "";
    if (n === 0) return ` · <span class="msg-hops" title="0 Hops — Direkt-Empfang">·0</span>`;
    return ` · <span class="msg-hops" title="${n} Hop${n === 1 ? "" : "s"} im Mesh">↗${n}</span>`;
  }

  function appendMessages(list, replace) {
    const box = document.getElementById("conv-messages");
    if (replace) box.innerHTML = "";
    for (const m of list) {
      const cls = m.direction === "out" ? "out" : "in";
      const who = m.direction === "out"
        ? "me"
        : (m.peer_name || (m.peer_pubkey_hex ? shortHex(m.peer_pubkey_hex, 8) : "?"));
      // Hops nur bei eingehenden anzeigen — eigene Out-Pakete haben kein
      // gemessenes Hop-Wert (wir verschicken sie, der Echo-Hop kommt
      // separat, ggf. dedupliziert).
      const hopsTxt = m.direction === "in" ? fmtHops(m.hops) : "";
      const div = document.createElement("div");
      div.className = "message " + cls;
      div.innerHTML = `<div class="msg-meta">${escText(who)} · ${fmtDate(m.ts)}${hopsTxt}</div>
                       <div class="msg-text">${escText(m.text || "")}</div>`;
      box.appendChild(div);
      if (m.ts) lastActiveTs = m.ts;
    }
    if (list.length) box.scrollTop = box.scrollHeight;
  }

  function markActiveThread() {
    document.querySelectorAll(".thread-item").forEach(el => el.classList.remove("active"));
    // exakte Highlight kommt mit dem nächsten loadThreads-Render
  }

  function armActiveTimer() {
    if (activeTimer) clearInterval(activeTimer);
    activeTimer = setInterval(() => {
      if (!active) return;
      if (active.kind === "dm") loadDmMessages(active.peer, false);
      else if (active.kind === "channel") loadChannelMessages(active.channel_id, false);
    }, POLL_ACTIVE_MS);
  }

  // ---------- Send ----------
  document.getElementById("conv-compose").addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!active) return;
    const t = document.getElementById("conv-text");
    const text = t.value.trim();
    if (!text) return;
    const fd = new FormData();
    fd.append("identity_id", IDENTITY_ID);
    fd.append("text", text);
    let endpoint;
    if (active.kind === "dm") {
      fd.append("peer_pubkey_hex", active.peer);
      endpoint = `${API}/messages/dm`;
    } else {
      fd.append("channel_id", active.channel_id);
      endpoint = `${API}/messages/channel`;
    }
    const r = await fetch(endpoint, {method:"POST", body: fd, credentials:"same-origin"});
    if (r.ok) {
      t.value = "";
      lastActiveTs = null;
      if (active.kind === "dm") await loadDmMessages(active.peer, true);
      else await loadChannelMessages(active.channel_id, true);
      loadThreads();
    } else {
      alert("send failed: " + r.status);
    }
  });

  document.getElementById("dm-new").addEventListener("submit", (e) => {
    e.preventDefault();
    const v = document.getElementById("dm-new-peer").value.trim();
    // Hex direkt
    if (/^[0-9a-fA-F]{64}$/.test(v)) {
      selectDm(v.toLowerCase(), null);
      document.getElementById("dm-new-peer").value = "";
      return;
    }
    // exakter Name aus Targets
    const lower = v.replace(/^@/, "").toLowerCase();
    const exact = AT_TARGETS.find(t => t.pubkey_hex && t.name.toLowerCase() === lower);
    if (exact) {
      selectDm(exact.pubkey_hex.toLowerCase(), exact.name);
      document.getElementById("dm-new-peer").value = "";
      return;
    }
    alert("Kein Kontakt mit diesem Namen, oder Pubkey ist nicht 64 Hex-Zeichen.");
  });

  // ---------- @-Auto-Complete ----------
  // mode = "insert" → "@[Name] " in den Text einfügen (Compose-Feld);
  //   trigger ist "@" mit Whitespace davor.
  // mode = "pick"   → onPick(target) callbacken, Input leeren (DM-Picker);
  //   trigger ist jedes Tippen (kein @ nötig). Hex-Pubkey schließt Popup.
  function attachAtComplete(input, popup, opts={}) {
    const mode = opts.mode || "insert";
    const onPick = opts.onPick || (() => {});
    const filter = opts.filter || ((t) => true);
    let activeIdx = 0;
    let matches = [];
    let atIdx = -1;

    function close() {
      popup.hidden = true;
      popup.innerHTML = "";
      atIdx = -1;
      matches = [];
    }

    function render() {
      popup.innerHTML = "";
      matches.forEach((t, i) => {
        const el = document.createElement("div");
        el.className = "at-item" + (i === activeIdx ? " active" : "");
        const sub = t.pubkey_hex
          ? `<span class="at-sub">${t.pubkey_hex.slice(0,8)}…</span>`
          : '<span class="at-sub">channel</span>';
        el.innerHTML = `<span class="at-name">${escText(t.name)}</span>${sub}`;
        el.addEventListener("mousedown", (e) => { e.preventDefault(); apply(i); });
        popup.appendChild(el);
      });
      popup.hidden = matches.length === 0;
    }

    function apply(idx) {
      const t = matches[idx];
      if (!t) return;
      if (mode === "pick") {
        onPick(t);
        input.value = "";
        close();
        return;
      }
      if (atIdx < 0) return;
      const v = input.value;
      const cursor = input.selectionStart;
      const insert = `@[${t.name}] `;
      input.value = v.slice(0, atIdx) + insert + v.slice(cursor);
      const newCursor = atIdx + insert.length;
      input.focus();
      input.setSelectionRange(newCursor, newCursor);
      close();
    }

    function update() {
      const v = input.value;
      let q;
      if (mode === "pick") {
        // Pick-Modus: jedes Tippen öffnet, Hex-Pubkey schließt
        if (/^[0-9a-fA-F]{64}$/.test(v.trim())) { close(); return; }
        const trimmed = v.trim().replace(/^@/, "");
        if (!trimmed) { close(); return; }
        q = trimmed.toLowerCase();
        atIdx = -1;
      } else {
        const cursor = input.selectionStart;
        const before = v.slice(0, cursor);
        const m = before.match(/(^|[\s])@([^@\s\[\]]*)$/);
        if (!m) { close(); return; }
        atIdx = before.length - m[2].length - 1;
        q = m[2].toLowerCase();
      }
      matches = AT_TARGETS
        .filter(filter)
        .filter(t => t.name.toLowerCase().includes(q))
        .slice(0, 12);
      if (!matches.length) { close(); return; }
      activeIdx = 0;
      render();
    }

    input.addEventListener("input", update);
    input.addEventListener("click", update);
    input.addEventListener("keydown", (e) => {
      if (popup.hidden) return;
      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = (activeIdx + 1) % matches.length;
        render();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = (activeIdx - 1 + matches.length) % matches.length;
        render();
      } else if (e.key === "Enter" || e.key === "Tab") {
        e.preventDefault();
        apply(activeIdx);
      } else if (e.key === "Escape") {
        e.preventDefault();
        close();
      }
    });
    input.addEventListener("blur", () => setTimeout(close, 100));
  }

  attachAtComplete(
    document.getElementById("conv-text"),
    document.getElementById("conv-at-popup"),
  );
  attachAtComplete(
    document.getElementById("dm-new-peer"),
    document.getElementById("dm-new-popup"),
    {
      mode: "pick",
      filter: (t) => !!t.pubkey_hex,
      onPick: (t) => selectDm(t.pubkey_hex.toLowerCase(), t.name),
    },
  );

  // ---------- Map ----------
  let mapInstance = null;
  let mapMarkers = null;
  let mapAutoTimer = null;

  async function ensureMap() {
    const status = document.getElementById("map-status");
    if (typeof L === "undefined") {
      status.textContent = "Leaflet konnte nicht geladen werden.";
      return;
    }
    if (!mapInstance) {
      // Default-Center ~Köln, wird gleich auf Pins gefittet
      mapInstance = L.map("node-map").setView([51.0, 7.0], 8);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "© OpenStreetMap-Mitwirkende",
      }).addTo(mapInstance);
      mapMarkers = L.layerGroup().addTo(mapInstance);
    } else {
      // Tab erst sichtbar geworden → invalidate damit Leaflet die Größe
      // korrekt neu berechnet.
      setTimeout(() => mapInstance.invalidateSize(), 50);
    }
    await refreshMap();
    await refreshTelemetryList();
  }

  async function refreshTelemetryList() {
    const box = document.getElementById("telemetry-list");
    try {
      const r = await fetch(`${API}/identities/${IDENTITY_ID}/contacts`, {credentials:"same-origin"});
      if (!r.ok) { box.textContent = "Fehler: " + r.status; return; }
      const list = await r.json();
      if (!list.length) {
        box.innerHTML = '<div class="thread-empty" style="color:var(--muted);padding:.5rem">Keine Kontakte.</div>';
        return;
      }
      // Sortierung: ohne Geo zuerst, dann nach last_seen
      list.sort((a, b) => {
        const aHasGeo = a.lat != null && a.lon != null;
        const bHasGeo = b.lat != null && b.lon != null;
        if (aHasGeo !== bHasGeo) return aHasGeo ? 1 : -1;
        return (b.last_seen_at || "").localeCompare(a.last_seen_at || "");
      });
      box.innerHTML = "";
      for (const c of list) {
        const row = document.createElement("div");
        row.className = "telemetry-row";
        const hasGeo = c.lat != null && c.lon != null;
        const star = c.favorite ? '<span style="color:gold">★</span> ' : '';
        const geo = hasGeo
          ? `<span class="telemetry-geo">📍 ${c.lat.toFixed(4)}, ${c.lon.toFixed(4)}</span>`
          : '<span class="telemetry-geo telemetry-geo-missing">— kein Geo</span>';
        row.innerHTML = `
          <div class="telemetry-name">${star}${escText(c.peer_name || c.peer_pubkey_hex.slice(0,8))}</div>
          <div class="telemetry-meta"><code>${c.peer_pubkey_hex.slice(0,12)}…</code> · ${fmtTime(c.last_seen_at)}</div>
          ${geo}
        `;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = "📡 Telemetrie";
        btn.className = "telemetry-btn";
        btn.addEventListener("click", () => requestTelemetry(c.peer_pubkey_hex, c.peer_name || c.peer_pubkey_hex.slice(0,8)));
        row.appendChild(btn);
        box.appendChild(row);
      }
    } catch (e) {
      box.textContent = "Fehler: " + e;
    }
  }

  async function requestTelemetry(peerHex, label) {
    const status = document.getElementById("telemetry-status");
    status.textContent = `Anfrage an ${label} gesendet — warte auf RESPONSE…`;
    try {
      const r = await fetch(
        `${API}/identities/${IDENTITY_ID}/contacts/${peerHex}/telemetry`,
        {method: "POST", credentials: "same-origin"},
      );
      if (!r.ok) {
        status.textContent = `Fehler ${r.status} bei ${label}`;
        return;
      }
    } catch (e) {
      status.textContent = `Sendefehler: ${e}`;
      return;
    }
    // 30 s lang alle 5 s Map + Liste reladen — die Antwort kann mehrere Hops dauern
    let attempts = 0;
    if (mapAutoTimer) clearInterval(mapAutoTimer);
    mapAutoTimer = setInterval(async () => {
      attempts++;
      await refreshMap();
      await refreshTelemetryList();
      if (attempts >= 6) {
        clearInterval(mapAutoTimer);
        mapAutoTimer = null;
        const cur = document.getElementById("telemetry-status").textContent;
        if (cur.startsWith("Anfrage")) {
          status.textContent = `${label}: keine Antwort innerhalb 30 s (Knoten offline oder kein Geo).`;
        }
      }
    }, 5000);
  }

  async function refreshMap() {
    const status = document.getElementById("map-status");
    try {
      const r = await fetch(`${API}/identities/${IDENTITY_ID}/map`, {credentials:"same-origin"});
      if (!r.ok) { status.textContent = "Fehler: " + r.status; return; }
      const pins = await r.json();
      mapMarkers.clearLayers();
      const bounds = [];
      for (const p of pins) {
        if (typeof p.lat !== "number" || typeof p.lon !== "number") continue;
        const popup = `<strong>${escText(p.peer_name || "?")}</strong><br>` +
                      `<code>${p.peer_pubkey_hex.slice(0,16)}…</code><br>` +
                      `<small>last seen: ${fmtDate(p.last_seen_at)}</small>`;
        const marker = L.circleMarker([p.lat, p.lon], {
          radius: p.favorite ? 8 : 6,
          color: p.favorite ? "#ffd866" : "#82aaff",
          weight: 2,
          fillColor: p.favorite ? "#ffd866" : "#82aaff",
          fillOpacity: 0.7,
        }).bindPopup(popup);
        mapMarkers.addLayer(marker);
        bounds.push([p.lat, p.lon]);
      }
      status.textContent = pins.length + " Knoten mit Geokoordinaten";
      if (bounds.length === 1) {
        mapInstance.setView(bounds[0], 12);
      } else if (bounds.length > 1) {
        mapInstance.fitBounds(bounds, {padding: [40, 40], maxZoom: 13});
      }
    } catch (e) {
      status.textContent = "Fehler: " + e;
    }
  }

  // ---------- Init / Restore ----------
  function applyConvSpec(spec) {
    if (!spec) return false;
    if (spec.startsWith("dm:")) {
      const peer = spec.slice(3);
      if (/^[0-9a-fA-F]{64}$/.test(peer)) { selectDm(peer.toLowerCase(), null); return true; }
    } else if (spec.startsWith("ch:")) {
      const id = spec.slice(3);
      selectChannel(id, id.slice(0,8));
      return true;
    }
    return false;
  }

  const VALID_TABS = ["chats", "map", "settings"];

  function restoreState() {
    const s = parseHash();
    // Legacy-Hashes: alte tab=dms / tab=channels mappen auf "chats"
    let tab = s.tab;
    if (tab === "dms" || tab === "channels") tab = "chats";
    if (!VALID_TABS.includes(tab)) tab = restoredTab() || "chats";
    showTab(tab);

    // Conv: Hash hat Vorrang, sonst localStorage
    let convSpec = s.conv || "";
    if (!convSpec) convSpec = restoredConv();
    if (tab === "chats") {
      loadThreads().then(() => applyConvSpec(convSpec));
    } else if (tab === "map") {
      ensureMap();
    }
  }

  setInterval(loadThreads, POLL_THREADS_MS);
  restoreState();
  window.addEventListener("hashchange", () => {
    const s = parseHash();
    let tab = s.tab;
    if (tab === "dms" || tab === "channels") tab = "chats";
    if (VALID_TABS.includes(tab)) {
      showTab(tab);
      if (tab === "map") ensureMap();
    }
    if (s.conv) applyConvSpec(s.conv);
  });
})();
</script>
{% endblock %}
