{% extends "base.html.j2" %}
{% block title %}{{ identity.name }} — Companion{% endblock %}
{% block head_extra %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}
{% block content %}
  <p style="margin:0 0 .5rem"><a href="/companion/">← Companion-Übersicht</a></p>

  <div class="card" style="margin-bottom:1rem">
    <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem">
      <div>
        <h1 id="ident-name" style="margin:0">{{ identity.name }}</h1>
        <span class="scope-{{ 'public' if identity.scope == 'public' else 'pool' }}">{{ identity.scope }}</span>
        · <code title="{{ identity.pubkey.hex() }}">{{ identity.pubkey.hex()[:16] }}…</code>
      </div>
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn" data-tab="chats">Chats</button>
    <button class="tab-btn" data-tab="map">Karte</button>
    <button class="tab-btn" data-tab="reach">Erreichbarkeit</button>
    <button class="tab-btn" data-tab="settings">Settings</button>
  </div>

  {# ---------- Chats (DMs + Channels unified) ---------- #}
  <section class="tab-panel" data-tab="chats">
    <div class="card messenger" data-mobile-view="threads">
      <aside class="thread-list" id="threads">
        <form id="dm-search-form" class="thread-new" onsubmit="return false">
          <input id="dm-search" type="search" autocomplete="off"
                 autocapitalize="off" spellcheck="false"
                 placeholder="Suchen oder Pubkey-Hex… (Prefix ? für Volltext)">
        </form>
        <div id="search-hits" style="display:none"></div>
        <div id="thread-list">
          <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
        </div>
        <button type="button" id="thread-jump-unread" class="thread-unread-jump" hidden
                title="Zu den ungelesenen Nachrichten weiter unten springen"></button>
      </aside>
      <div class="thread-view">
        <div id="conv-header" class="thread-header">
          <button type="button" class="conv-back" aria-label="Zurück zur Liste">←</button>
          <span id="conv-title">Wähle einen Chat oder starte einen DM.</span>
          <div id="conv-actions" class="conv-actions" hidden>
            <button type="button" id="btn-login" class="conv-action-btn" title="ANON_REQ-Login (Repeater-Status oder Room-Beitritt — Passwort wird beim Klick erfragt)">🔑</button>
            <span id="login-pill" class="login-pill" hidden></span>
            <button type="button" id="btn-status" class="conv-action-btn" title="Status (Ping + Repeater-Stats) anfragen — vorher Login nötig">ℹ</button>
            <button type="button" id="btn-telemetry" class="conv-action-btn" title="Telemetrie (GPS + Sensoren) anfragen">📡</button>
          </div>
          <label id="translate-toggle-wrap" class="translate-toggle"
                 title="Eingehende Nachrichten automatisch ins Deutsche übersetzen">
            <input type="checkbox" id="translate-toggle"><span aria-hidden="true">🌐</span>
          </label>
          <span id="sse-dot" class="sse-dot" title="verbinde…"></span>
        </div>
        <div id="conv-messages" class="message-list"></div>
        <form id="conv-compose" class="compose-row" style="display:none">
          <div class="at-input-wrap">
            <input id="conv-text" required autocomplete="off"
                   autocapitalize="sentences" enterkeyhint="send"
                   placeholder="Nachricht… (@ für Auto-Complete)">
            <div class="at-popup" id="conv-at-popup" hidden></div>
          </div>
          <button type="submit">Senden</button>
        </form>
      </div>
    </div>
  </section>

  {# ---------- Map ---------- #}
  <section class="tab-panel" data-tab="map">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
        <h2 style="margin:0">Karte beobachteter Knoten</h2>
        <span id="map-status" style="color:var(--muted);font-size:.85em"></span>
      </div>
      <div id="node-map" class="node-map"></div>
      <div class="map-legend">
        <span><span class="legend-dot legend-dot--fresh"></span>letzte 15 Min</span>
        <span><span class="legend-dot legend-dot--recent"></span>letzte Stunde</span>
        <span><span class="legend-dot legend-dot--stale"></span>letzte 24 h</span>
        <span><span class="legend-dot legend-dot--gone"></span>älter</span>
        <span><span class="legend-dot legend-dot--favorite"></span>Favorit</span>
      </div>
      <p style="margin-top:.5rem;font-size:.85em;color:var(--muted)">
        Letzte 72 h. Ältere Knoten werden ausgeblendet — außer sie sind
        Favorit oder es gab DM-Verkehr mit ihnen. Pins entstehen aus
        Lat/Lon in ADVERTs ODER aus REQ_TYPE_GET_TELEMETRY_DATA
        (LPP_GPS) — anfragebar pro Kontakt unten. Knoten mit ungültigen
        oder unplausiblen Koordinaten (Null-Insel, weit außerhalb des
        Hauptclusters) werden ignoriert. Pin-Farbe = Frische der letzten
        Aktivität. Klick aufs Popup öffnet die DM.
      </p>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Kontakte — Telemetrie anfragen</h3>
      <p style="font-size:.85em;color:var(--muted);margin-top:0">
        REQ-Paket via LoRa an den Peer; Antwort kommt asynchron, Karte
        aktualisiert sich nach 5 s Polling. Kostet Mesh-Bandbreite —
        sparsam einsetzen.
      </p>
      <div id="telemetry-status" style="color:var(--muted);font-size:.85em;margin-bottom:.5rem"></div>
      <div id="telemetry-list" class="telemetry-list">
        <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
      </div>
    </div>
  </section>

  {# ---------- Erreichbarkeit ---------- #}
  <section class="tab-panel" data-tab="reach">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
        <h2 style="margin:0">Erreichbarkeit</h2>
        <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
          <label style="font-size:.85em;color:var(--muted)">Fenster
            <select id="reach-window">
              <option value="1">1h</option>
              <option value="6">6h</option>
              <option value="24" selected>24h</option>
              <option value="72">72h</option>
              <option value="168">7d</option>
            </select>
          </label>
          <button type="button" id="btn-probe-favs">Favoriten jetzt proben</button>
        </div>
      </div>
      <p style="font-size:.85em;color:var(--muted);margin-top:0">
        <strong>last seen</strong>: letzter Empfang vom Peer (Advert/Nachricht).
        <strong>out-path</strong>: Direkt-Pfad gelernt = Peer hat uns kürzlich
        bestätigt empfangen. <strong>Probe</strong>: explizite "[probe]"-DM
        mit ACK-Messung — funktioniert nur bei <em>Chat-Knoten</em>.
        Repeater/Rooms/Sensoren ACKen keine DMs (n/a). Loss%/RTT-Median
        über das gewählte Fenster. Probe kostet Mesh-Bandbreite — gezielt
        einsetzen.
      </p>
      <div id="reach-status" style="color:var(--muted);font-size:.85em;margin-bottom:.5rem"></div>
      <table class="reach-table">
        <thead>
          <tr>
            <th>Kontakt</th>
            <th>last seen</th>
            <th>out-path</th>
            <th>Probes ({{ '24h' }})</th>
            <th>Loss</th>
            <th>RTT med</th>
            <th>letzte Probe</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="reach-tbody">
          <tr><td colspan="8" style="color:var(--muted);padding:.5rem">lade …</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {# ---------- Settings ---------- #}
  <section class="tab-panel" data-tab="settings">
    <div class="card">
      <h2>Identität</h2>
      <form method="post" action="/companion/{{ identity.id }}/rename">
        <label>Name
          <input name="name" required maxlength="64" value="{{ identity.name }}">
        </label>
        <button type="submit">Umbenennen</button>
      </form>
      <p style="margin-top:1rem;font-size:.9em;color:var(--muted)">
        Pubkey: <code>{{ identity.pubkey.hex() }}</code><br>
        Scope: <code>{{ identity.scope }}</code><br>
        Created: {{ identity.created_at | localtime }}
      </p>
      <p style="margin-top:1rem">
        Echo-Bot: <strong>{{ 'an' if identity.is_echo else 'aus' }}</strong>
        — beantwortet eingehende DMs automatisch mit Text + Metadaten (hops, route, age, len).
      </p>
      <form method="post" action="/companion/{{ identity.id }}/path-hash-mode"
            style="margin-top:1rem;display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
        <label style="margin:0">Path-Hash-Größe
          <select name="mode">
            <option value="0" {% if identity.path_hash_mode == 0 %}selected{% endif %}>1 Byte (default, kompatibel)</option>
            <option value="1" {% if identity.path_hash_mode == 1 %}selected{% endif %}>2 Byte (Repeater ≥ v1.14)</option>
            <option value="2" {% if identity.path_hash_mode == 2 %}selected{% endif %}>3 Byte (Repeater ≥ v1.14)</option>
          </select>
        </label>
        <button type="submit" style="margin:0">Übernehmen</button>
      </form>
      <p style="font-size:.85em;color:var(--muted);margin:.25rem 0 0">
        Gilt für alle ausgehenden Pakete dieser Identität (DM via FLOOD,
        Channel-Posts, eigene Adverts). Repeater &lt; v1.14 droppen
        2-/3-Byte-Pakete still — vor dem Umstellen sicherstellen, dass
        die Repeater im Pfad aktuell sind.
      </p>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
        <form method="post" action="/companion/{{ identity.id }}/advert" style="margin:0">
          <button type="submit" style="margin:0">Advert jetzt senden</button>
        </form>
        <form method="post" action="/companion/{{ identity.id }}/echo" style="margin:0">
          <input type="hidden" name="enabled" value="{{ 'false' if identity.is_echo else 'true' }}">
          <button type="submit" style="margin:0">
            {{ 'Echo-Bot deaktivieren' if identity.is_echo else 'Echo-Bot aktivieren' }}
          </button>
        </form>
        <form method="post" action="/companion/{{ identity.id }}/archive" style="margin:0"
              onsubmit="return confirm('Identität archivieren? Sie verschwindet aus der Liste und sendet keine Adverts mehr.');">
          <button type="submit" style="margin:0;background:var(--danger)">archivieren</button>
        </form>
      </div>
    </div>

    <div class="card">
      <h2>Kanäle ({{ channels | length }})</h2>
      {% if channels %}
        <table>
          <thead><tr><th></th><th>Name</th><th>Hash</th><th></th></tr></thead>
          <tbody>
          {% for ch in channels %}
            <tr>
              <td title="{{ 'Favorit' if ch.favorite else 'Kein Favorit' }}"
                  style="color:{{ 'gold' if ch.favorite else 'var(--muted)' }};font-size:1.1em">
                {{ '★' if ch.favorite else '☆' }}
              </td>
              <td>{{ ch.name }}</td>
              <td><code>{{ ch.channel_hash.hex() }}</code></td>
              <td>
                <form method="post" action="/companion/channels/{{ ch.id }}/delete"
                      style="margin:0"
                      onsubmit="return confirm('Kanal {{ ch.name }} löschen?');">
                  <button type="submit"
                          style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                    löschen
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p>Noch keine Kanäle.</p>
      {% endif %}

      <h3 style="margin-top:1rem">Kanal hinzufügen</h3>
      <form method="post" action="/companion/{{ identity.id }}/channels">
        <label>Name
          <input name="name" required maxlength="64" placeholder="z.B. tech">
        </label>
        <label>Passwort
          <input name="password" required maxlength="128"
                 placeholder="geteiltes Channel-Passwort">
        </label>
        <button type="submit">Hinzufügen</button>
      </form>
      <p style="font-size:.85em;color:var(--muted)">
        Secret = <code>sha256(name + ":" + password)[:32]</code>. Alle
        Teilnehmer brauchen denselben Namen und dasselbe Passwort.
      </p>
    </div>

    {# ---------- API-Tokens ---------- #}
    <div class="card">
      <h2>API-Tokens</h2>
      <p style="font-size:.9em;color:var(--muted);margin:0 0 .75rem">
        Bearer-Tokens für Skripte / Home-Assistant / CLI, die diese
        Identität ansprechen sollen. Ein Token sperrt auf diese Identität.
        Scope <code>read</code> = lesen, <code>write</code> = DM/Channel
        senden, <code>admin</code> = Identitäts-Einstellungen. Token-Anlage
        und Revoke gehen nur über das Web-Login.
      </p>

      <table id="tokens-table">
        <thead>
          <tr><th>Name</th><th>Scopes</th><th>Erstellt</th><th>Zuletzt</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        {% for t in api_tokens %}
          <tr data-token-id="{{ t.id }}">
            <td>{{ t.name }}</td>
            <td><code>{{ t.scopes }}</code></td>
            <td>{{ t.created_at | localtime }}</td>
            <td>{% if t.last_used_at %}{{ t.last_used_at | localtime }}{% else %}—{% endif %}</td>
            <td class="tok-status">
              {% if t.revoked_at %}<span style="color:var(--danger)">revoked</span>
              {% elif t.expires_at %}<span title="läuft ab">expires {{ t.expires_at | localtime }}</span>
              {% else %}aktiv{% endif %}
            </td>
            <td>
              {% if not t.revoked_at %}
                <button type="button" class="tok-revoke"
                        style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                  revoken
                </button>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        {% if not api_tokens %}
          <tr id="tokens-empty"><td colspan="6" style="color:var(--muted)">Noch kein Token.</td></tr>
        {% endif %}
        </tbody>
      </table>

      <h3 style="margin-top:1rem">Neuen Token erstellen</h3>
      <form id="tokens-create-form" onsubmit="return false"
            style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end">
        <label style="margin:0">Name
          <input name="name" required maxlength="64" placeholder="z.B. ha-bridge">
        </label>
        <fieldset style="margin:0;padding:.25rem .5rem;border:1px solid var(--border)">
          <legend style="font-size:.85em">Scopes</legend>
          <label style="display:inline-flex;gap:.25rem;align-items:center;margin-right:.75rem">
            <input type="checkbox" name="scope" value="read" checked> read
          </label>
          <label style="display:inline-flex;gap:.25rem;align-items:center;margin-right:.75rem">
            <input type="checkbox" name="scope" value="write"> write
          </label>
          <label style="display:inline-flex;gap:.25rem;align-items:center">
            <input type="checkbox" name="scope" value="admin"> admin
          </label>
        </fieldset>
        <label style="margin:0">Läuft ab (optional, ISO-Datum)
          <input name="expires_at" type="text" placeholder="2027-01-01T00:00:00Z" pattern=".{0}|.{10,}">
        </label>
        <button type="submit" style="margin:0">Erstellen</button>
      </form>

      <div id="token-plaintext-box" hidden
           style="margin-top:1rem;padding:.75rem;border:1px solid var(--warn,#a60);background:rgba(170,100,0,.08);border-radius:.25rem">
        <strong>Token (wird nur einmal angezeigt — jetzt kopieren!):</strong>
        <div style="display:flex;gap:.5rem;align-items:center;margin-top:.5rem">
          <code id="token-plaintext"
                style="flex:1;user-select:all;word-break:break-all;font-size:1rem"></code>
          <button type="button" id="token-copy-btn" style="margin:0">Kopieren</button>
        </div>
      </div>
      <div id="tokens-error" style="margin-top:.5rem;color:var(--danger)" hidden></div>
    </div>
  </section>

  <script>
    (() => {
      const IDENT = "{{ identity.id }}";
      const tableBody = document.querySelector("#tokens-table tbody");
      const empty = document.getElementById("tokens-empty");
      const form = document.getElementById("tokens-create-form");
      const plainBox = document.getElementById("token-plaintext-box");
      const plainEl = document.getElementById("token-plaintext");
      const errEl = document.getElementById("tokens-error");

      function fmtLocal(iso) {
        if (!iso) return "—";
        try { return new Date(iso).toLocaleString(); } catch { return iso; }
      }

      function showError(msg) {
        errEl.textContent = msg;
        errEl.hidden = false;
      }
      function clearError() { errEl.hidden = true; errEl.textContent = ""; }

      function attachRevoke(btn) {
        btn.addEventListener("click", async () => {
          const tr = btn.closest("tr");
          const tid = tr.dataset.tokenId;
          if (!confirm("Token unwiderruflich revoken?")) return;
          btn.disabled = true;
          try {
            const r = await fetch(`/api/v1/companion/tokens/${tid}/revoke`,
              {method: "POST", credentials: "same-origin"});
            if (!r.ok) { showError(`Revoke fehlgeschlagen: ${r.status}`); btn.disabled = false; return; }
            const data = await r.json();
            tr.querySelector(".tok-status").innerHTML =
              `<span style="color:var(--danger)">revoked</span>`;
            btn.remove();
          } catch (e) {
            showError(String(e));
            btn.disabled = false;
          }
        });
      }
      document.querySelectorAll(".tok-revoke").forEach(attachRevoke);

      form.addEventListener("submit", async () => {
        clearError();
        plainBox.hidden = true;
        const fd = new FormData(form);
        const scopes = fd.getAll("scope").join(",");
        if (!scopes) { showError("Mindestens ein Scope wählen."); return; }
        const body = new URLSearchParams();
        body.set("name", fd.get("name"));
        body.set("scopes", scopes);
        const exp = (fd.get("expires_at") || "").trim();
        if (exp) body.set("expires_at", exp);

        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/tokens`,
            {method: "POST", credentials: "same-origin", body});
          if (!r.ok) {
            const t = await r.text();
            showError(`${r.status}: ${t}`); return;
          }
          const t = await r.json();
          plainEl.textContent = t.token;
          plainBox.hidden = false;

          if (empty) empty.remove();
          const tr = document.createElement("tr");
          tr.dataset.tokenId = t.id;
          tr.innerHTML =
            `<td>${t.name.replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]))}</td>` +
            `<td><code>${t.scopes.join(",")}</code></td>` +
            `<td>${fmtLocal(t.created_at)}</td>` +
            `<td>—</td>` +
            `<td class="tok-status">${t.expires_at ? `<span title="läuft ab">expires ${fmtLocal(t.expires_at)}</span>` : "aktiv"}</td>` +
            `<td><button type="button" class="tok-revoke" style="margin:0;padding:.25rem .6rem;background:var(--danger)">revoken</button></td>`;
          tableBody.prepend(tr);
          attachRevoke(tr.querySelector(".tok-revoke"));
          form.reset();
        } catch (e) {
          showError(String(e));
        }
      });

      document.getElementById("token-copy-btn").addEventListener("click", async () => {
        try { await navigator.clipboard.writeText(plainEl.textContent); }
        catch { /* Clipboard kann blockiert sein; user-select:all reicht als Fallback */ }
      });
    })();
  </script>

  <script id="companion-bootstrap" type="application/json">
    {"identityId": "{{ identity.id }}", "identityName": {{ identity.name | tojson }}, "atTargets": {{ at_targets | tojson }}}
  </script>
  <script src="/static/companion.js?v={{ asset_version }}" defer></script>
{% endblock %}
