{% extends "base.html.j2" %}
{% block title %}{{ identity.name }} — Companion{% endblock %}
{% block head_extra %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}
{% block content %}
  <p style="margin:0 0 .5rem"><a href="/companion/">← Companion-Übersicht</a></p>

  <div class="card" style="margin-bottom:1rem">
    <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.5rem">
      <div>
        <h1 id="ident-name" style="margin:0">{{ identity.name }}</h1>
        <span class="scope-{{ 'public' if identity.scope == 'public' else 'pool' }}">{{ identity.scope }}</span>
        · <code title="{{ identity.pubkey.hex() }}">{{ identity.pubkey.hex()[:16] }}…</code>
      </div>
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn" data-tab="chats">Chats</button>
    <button class="tab-btn" data-tab="map">Karte</button>
    <button class="tab-btn" data-tab="reach">Erreichbarkeit</button>
    <button class="tab-btn" data-tab="settings">Settings</button>
  </div>

  {# ---------- Chats (DMs + Channels unified) ---------- #}
  <section class="tab-panel" data-tab="chats">
    <div class="card messenger" data-mobile-view="threads">
      <aside class="thread-list" id="threads">
        <form id="dm-search-form" class="thread-new" onsubmit="return false">
          <input id="dm-search" type="search" autocomplete="off"
                 autocapitalize="off" spellcheck="false"
                 placeholder="Suchen oder Pubkey-Hex… (Prefix ? für Volltext)">
        </form>
        <div id="search-hits" style="display:none"></div>
        <div id="thread-list">
          <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
        </div>
        <button type="button" id="thread-jump-unread" class="thread-unread-jump" hidden
                title="Zu den ungelesenen Nachrichten weiter unten springen"></button>
      </aside>
      <div class="thread-view">
        <div id="conv-header" class="thread-header">
          <button type="button" class="conv-back" aria-label="Zurück zur Liste">←</button>
          <span id="conv-title">Wähle einen Chat oder starte einen DM.</span>
          <div id="conv-actions" class="conv-actions" hidden>
            <button type="button" id="btn-login" class="conv-action-btn" title="ANON_REQ-Login (Repeater-Status oder Room-Beitritt — Passwort wird beim Klick erfragt)">🔑</button>
            <span id="login-pill" class="login-pill" hidden></span>
            <button type="button" id="btn-status" class="conv-action-btn" title="Status (Ping + Repeater-Stats) anfragen — vorher Login nötig">ℹ</button>
            <button type="button" id="btn-telemetry" class="conv-action-btn" title="Telemetrie (GPS + Sensoren) anfragen">📡</button>
          </div>
          <label id="translate-toggle-wrap" class="translate-toggle"
                 title="Eingehende Nachrichten automatisch ins Deutsche übersetzen">
            <input type="checkbox" id="translate-toggle"><span aria-hidden="true">🌐</span>
          </label>
          <span id="sse-dot" class="sse-dot" title="verbinde…"></span>
        </div>
        <div id="conv-messages" class="message-list"></div>
        <form id="conv-compose" class="compose-row" style="display:none">
          <div class="at-input-wrap">
            <input id="conv-text" required autocomplete="off"
                   autocapitalize="sentences" enterkeyhint="send"
                   placeholder="Nachricht… (@ für Auto-Complete)">
            <div class="at-popup" id="conv-at-popup" hidden></div>
          </div>
          <button type="submit">Senden</button>
        </form>
      </div>
    </div>
  </section>

  {# ---------- Map ---------- #}
  <section class="tab-panel" data-tab="map">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
        <h2 style="margin:0">Karte beobachteter Knoten</h2>
        <span id="map-status" style="color:var(--muted);font-size:.85em"></span>
      </div>
      <div id="node-map" class="node-map"></div>
      <div class="map-legend">
        <span><span class="legend-dot legend-dot--fresh"></span>letzte 15 Min</span>
        <span><span class="legend-dot legend-dot--recent"></span>letzte Stunde</span>
        <span><span class="legend-dot legend-dot--stale"></span>letzte 24 h</span>
        <span><span class="legend-dot legend-dot--gone"></span>älter</span>
        <span><span class="legend-dot legend-dot--favorite"></span>Favorit</span>
      </div>
      <p style="margin-top:.5rem;font-size:.85em;color:var(--muted)">
        Letzte 72 h. Ältere Knoten werden ausgeblendet — außer sie sind
        Favorit oder es gab DM-Verkehr mit ihnen. Pins entstehen aus
        Lat/Lon in ADVERTs ODER aus REQ_TYPE_GET_TELEMETRY_DATA
        (LPP_GPS) — anfragebar pro Kontakt unten. Knoten mit ungültigen
        oder unplausiblen Koordinaten (Null-Insel, weit außerhalb des
        Hauptclusters) werden ignoriert. Pin-Farbe = Frische der letzten
        Aktivität. Klick aufs Popup öffnet die DM.
      </p>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Kontakte — Telemetrie anfragen</h3>
      <p style="font-size:.85em;color:var(--muted);margin-top:0">
        REQ-Paket via LoRa an den Peer; Antwort kommt asynchron, Karte
        aktualisiert sich nach 5 s Polling. Kostet Mesh-Bandbreite —
        sparsam einsetzen.
      </p>
      <div id="telemetry-status" style="color:var(--muted);font-size:.85em;margin-bottom:.5rem"></div>
      <div id="telemetry-list" class="telemetry-list">
        <div class="thread-empty" style="color:var(--muted);padding:.5rem">lade …</div>
      </div>
    </div>
  </section>

  {# ---------- Erreichbarkeit ---------- #}
  <section class="tab-panel" data-tab="reach">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:.5rem">
        <h2 style="margin:0">Erreichbarkeit</h2>
        <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
          <label style="font-size:.85em;color:var(--muted)">Fenster
            <select id="reach-window">
              <option value="1">1h</option>
              <option value="6">6h</option>
              <option value="24" selected>24h</option>
              <option value="72">72h</option>
              <option value="168">7d</option>
            </select>
          </label>
          <button type="button" id="btn-probe-favs">Favoriten jetzt proben</button>
        </div>
      </div>
      <p style="font-size:.85em;color:var(--muted);margin-top:0">
        <strong>last seen</strong>: letzter Empfang vom Peer (Advert/Nachricht).
        <strong>out-path</strong>: Direkt-Pfad gelernt = Peer hat uns kürzlich
        bestätigt empfangen. <strong>Probe</strong>: explizite "[probe]"-DM
        mit ACK-Messung — funktioniert nur bei <em>Chat-Knoten</em>.
        Repeater/Rooms/Sensoren ACKen keine DMs (n/a). Loss%/RTT-Median
        über das gewählte Fenster. Probe kostet Mesh-Bandbreite — gezielt
        einsetzen.
      </p>
      <div id="reach-status" style="color:var(--muted);font-size:.85em;margin-bottom:.5rem"></div>
      <table class="reach-table">
        <thead>
          <tr>
            <th>Kontakt</th>
            <th>last seen</th>
            <th>out-path</th>
            <th>Probes ({{ '24h' }})</th>
            <th>Loss</th>
            <th>RTT med</th>
            <th>letzte Probe</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="reach-tbody">
          <tr><td colspan="8" style="color:var(--muted);padding:.5rem">lade …</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  {# ---------- Settings ---------- #}
  <section class="tab-panel" data-tab="settings">
    <div class="card">
      <h2>Identität</h2>
      <form method="post" action="/companion/{{ identity.id }}/rename">
        <label>Name
          <input name="name" required maxlength="64" value="{{ identity.name }}">
        </label>
        <button type="submit">Umbenennen</button>
      </form>
      <p style="margin-top:1rem;font-size:.9em;color:var(--muted)">
        Pubkey: <code>{{ identity.pubkey.hex() }}</code><br>
        Scope: <code>{{ identity.scope }}</code><br>
        Created: {{ identity.created_at | localtime }}
      </p>
      <p style="margin-top:1rem">
        Echo-Bot: <strong>{{ 'an' if identity.is_echo else 'aus' }}</strong>
        — beantwortet eingehende DMs automatisch mit Text + Metadaten (hops, route, age, len).
      </p>
      <form method="post" action="/companion/{{ identity.id }}/path-hash-mode"
            style="margin-top:1rem;display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
        <label style="margin:0">Path-Hash-Größe
          <select name="mode">
            <option value="0" {% if identity.path_hash_mode == 0 %}selected{% endif %}>1 Byte (default, kompatibel)</option>
            <option value="1" {% if identity.path_hash_mode == 1 %}selected{% endif %}>2 Byte (Repeater ≥ v1.14)</option>
            <option value="2" {% if identity.path_hash_mode == 2 %}selected{% endif %}>3 Byte (Repeater ≥ v1.14)</option>
          </select>
        </label>
        <button type="submit" style="margin:0">Übernehmen</button>
      </form>
      <p style="font-size:.85em;color:var(--muted);margin:.25rem 0 0">
        Gilt für alle ausgehenden Pakete dieser Identität (DM via FLOOD,
        Channel-Posts, eigene Adverts). Repeater &lt; v1.14 droppen
        2-/3-Byte-Pakete still — vor dem Umstellen sicherstellen, dass
        die Repeater im Pfad aktuell sind.
      </p>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
        <form method="post" action="/companion/{{ identity.id }}/advert" style="margin:0">
          <button type="submit" style="margin:0">Advert jetzt senden</button>
        </form>
        <form method="post" action="/companion/{{ identity.id }}/echo" style="margin:0">
          <input type="hidden" name="enabled" value="{{ 'false' if identity.is_echo else 'true' }}">
          <button type="submit" style="margin:0">
            {{ 'Echo-Bot deaktivieren' if identity.is_echo else 'Echo-Bot aktivieren' }}
          </button>
        </form>
        <form method="post" action="/companion/{{ identity.id }}/archive" style="margin:0"
              onsubmit="return confirm('Identität archivieren? Sie verschwindet aus der Liste und sendet keine Adverts mehr.');">
          <button type="submit" style="margin:0;background:var(--danger)">archivieren</button>
        </form>
      </div>
    </div>

    <div class="card">
      <h2>Kanäle ({{ channels | length }})</h2>
      {% if channels %}
        <table>
          <thead><tr><th></th><th>Name</th><th>Hash</th><th>Status</th><th></th></tr></thead>
          <tbody>
          {% for ch in channels %}
            <tr{% if ch.archived_at %} style="opacity:.6"{% endif %}>
              <td title="{{ 'Favorit' if ch.favorite else 'Kein Favorit' }}"
                  style="color:{{ 'gold' if ch.favorite else 'var(--muted)' }};font-size:1.1em">
                {{ '★' if ch.favorite else '☆' }}
              </td>
              <td>{{ ch.name }}</td>
              <td><code>{{ ch.channel_hash.hex() }}</code></td>
              <td>
                {% if ch.archived_at %}
                  <span style="color:var(--muted)" title="archiviert {{ ch.archived_at | localtime }}">archiviert</span>
                {% else %}
                  aktiv
                {% endif %}
              </td>
              <td style="display:flex;gap:.25rem;flex-wrap:wrap">
                <button type="button"
                        class="ch-archive-btn"
                        data-ch-id="{{ ch.id }}"
                        data-archived="{{ '1' if ch.archived_at else '0' }}"
                        style="margin:0;padding:.25rem .6rem">
                  {{ 'wiederherstellen' if ch.archived_at else 'archivieren' }}
                </button>
                <form method="post" action="/companion/channels/{{ ch.id }}/delete"
                      style="margin:0">
                  <button type="submit"
                          style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                    löschen
                  </button>
                </form>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p>Noch keine Kanäle.</p>
      {% endif %}

      <h3 style="margin-top:1rem">Kanal hinzufügen</h3>
      <form method="post" action="/companion/{{ identity.id }}/channels">
        <label>Name
          <input name="name" required maxlength="64" placeholder="z.B. tech">
        </label>
        <label>Passwort
          <input name="password" required maxlength="128"
                 placeholder="geteiltes Channel-Passwort">
        </label>
        <button type="submit">Hinzufügen</button>
      </form>
      <p style="font-size:.85em;color:var(--muted)">
        Secret = <code>sha256(name + ":" + password)[:32]</code>. Alle
        Teilnehmer brauchen denselben Namen und dasselbe Passwort.
      </p>
    </div>

    {# ---------- Wetter-Auto-Posts ---------- #}
    <div class="card">
      <h2>Wetter-Auto-Posts</h2>
      <p style="font-size:.9em;color:var(--muted);margin:0 0 .75rem">
        Diese Identität postet periodisch das aktuelle Wetter aus Home
        Assistant in einen Kanal. Quelle ist eine HA-<code>weather.*</code>-
        Entity (z.B. <code>weather.home</code>); der Server liest sie über
        die HA-REST-API, formatiert eine kompakte Zeile mit Emoji und
        sendet sie via Channel-Post.
        {% if not weather_ha_enabled %}
          <br><strong style="color:var(--warn,#a60)">HA-Adapter ist nicht
          aktiv</strong> — neue Posts werden zwar gespeichert, aber erst
          ausgeliefert, wenn <code>homeassistant.enabled=true</code> in
          <code>app.yaml</code> + <code>MESHCORE_HA_TOKEN_FILE</code>
          gesetzt sind.
        {% endif %}
      </p>

      {# Template-Snippet für eine einzelne Sensor-Zeile — kommt sowohl in
         der bestehenden Liste als auch im JS-Add-Button zum Einsatz. #}
      <template id="wp-entity-row-template">
        <div class="wp-entity-row" style="display:flex;gap:.5rem;align-items:center;margin-bottom:.35rem">
          <input class="wp-entity-input" maxlength="128"
                 placeholder="weather.home oder sensor.…"
                 style="flex:1;min-width:18rem">
          <span class="wp-entity-preview" style="font-size:.85em;color:var(--muted);min-width:8rem"></span>
          <button type="button" class="wp-entity-remove"
                  title="Sensor entfernen" style="margin:0;padding:.2rem .55rem">−</button>
        </div>
      </template>

      <div id="weather-list">
      {% for wp in weather_posts %}
        {% set entities = (wp.ha_entity_id or '').split(',') %}
        <form class="wp-row" data-wp-id="{{ wp.id }}" onsubmit="return false"
              style="border:1px solid var(--border);border-radius:.25rem;padding:.75rem;margin-bottom:.75rem">
          <div style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end">
            <label style="margin:0">Kanal
              <select name="channel_id">
                {# Bestehender Post: den zugewiesenen Channel auch dann zeigen,
                   wenn er archiviert wurde — sonst bleibt das Dropdown leer
                   und der POST geht ohne channel_id raus. #}
                {% for ch in channels %}
                  {% if not ch.archived_at or ch.id == wp.channel_id %}
                    <option value="{{ ch.id }}"{% if ch.id == wp.channel_id %} selected{% endif %}>#{{ ch.name }}{% if ch.archived_at %} (archiviert){% endif %}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </label>
            <label style="margin:0">Intervall
              <select name="interval_s">
                <option value="3600"{% if wp.interval_s == 3600 %} selected{% endif %}>1 h</option>
                <option value="10800"{% if wp.interval_s == 10800 %} selected{% endif %}>3 h</option>
                <option value="21600"{% if wp.interval_s == 21600 %} selected{% endif %}>6 h</option>
                <option value="43200"{% if wp.interval_s == 43200 %} selected{% endif %}>12 h</option>
                <option value="86400"{% if wp.interval_s == 86400 %} selected{% endif %}>24 h</option>
              </select>
            </label>
            <label style="margin:0">Ort
              <input name="location_label" maxlength="64" value="{{ wp.location_label or '' }}">
            </label>
          </div>
          <div style="margin-top:.75rem">
            <strong style="display:block;margin-bottom:.25rem">HA-Entities</strong>
            <div class="wp-entities">
              {% for raw in entities %}
                {% set entity = raw.strip() %}
                {% if entity or loop.first %}
                  <div class="wp-entity-row" style="display:flex;gap:.5rem;align-items:center;margin-bottom:.35rem">
                    <input class="wp-entity-input" maxlength="128"
                           value="{{ entity }}"
                           placeholder="weather.home oder sensor.…"
                           style="flex:1;min-width:18rem">
                    <span class="wp-entity-preview"
                          style="font-size:.85em;color:var(--muted);min-width:8rem"></span>
                    <button type="button" class="wp-entity-remove"
                            title="Sensor entfernen" style="margin:0;padding:.2rem .55rem">−</button>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            <button type="button" class="wp-entity-add"
                    style="margin:0;padding:.25rem .75rem">+ Sensor</button>
          </div>
          <div style="margin-top:.5rem;font-size:.85em;color:var(--muted)">
            Zuletzt: {% if wp.last_posted_at %}{{ wp.last_posted_at | localtime }}{% else %}—{% endif %}
            · Status: {% if wp.enabled %}aktiv{% else %}<span style="color:var(--muted)">pausiert</span>{% endif %}
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.5rem">
            <button type="button" class="wp-save-btn" style="margin:0">Speichern</button>
            <button type="button" class="wp-toggle-btn" data-enabled="{{ '1' if wp.enabled else '0' }}" style="margin:0">
              {{ 'pausieren' if wp.enabled else 'aktivieren' }}
            </button>
            <button type="button" class="wp-delete-btn" style="margin:0;background:var(--danger)">löschen</button>
          </div>
          <div class="wp-error" hidden style="margin-top:.5rem;color:var(--danger)"></div>
        </form>
      {% endfor %}
      {% if not weather_posts %}
        <p id="weather-empty" style="color:var(--muted)">Noch kein Wetter-Auto-Post.</p>
      {% endif %}
      </div>

      <h3 style="margin-top:1rem">Neuer Wetter-Auto-Post</h3>
      {% set _active_channels = channels | rejectattr('archived_at') | list %}
      <form id="weather-create-form" onsubmit="return false"
            style="display:flex;flex-direction:column;gap:.75rem">
        <div style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end">
          <label style="margin:0">Kanal
            <select name="channel_id" required{% if not _active_channels %} disabled{% endif %}>
              {% for ch in _active_channels %}
                <option value="{{ ch.id }}"{% if ch.name == 'wetter' %} selected{% endif %}>#{{ ch.name }}</option>
              {% endfor %}
            </select>
          </label>
          <label style="margin:0">Intervall
            <select name="interval_s">
              <option value="3600">1 h</option>
              <option value="10800">3 h</option>
              <option value="21600" selected>6 h</option>
              <option value="43200">12 h</option>
              <option value="86400">24 h</option>
            </select>
          </label>
          <label style="margin:0">Ort (optional)
            <input name="location_label" maxlength="64" placeholder="z.B. Bonn">
          </label>
        </div>
        <div>
          <strong style="display:block;margin-bottom:.25rem">HA-Entities</strong>
          <div class="wp-entities">
            <div class="wp-entity-row" style="display:flex;gap:.5rem;align-items:center;margin-bottom:.35rem">
              <input class="wp-entity-input" maxlength="128"
                     placeholder="weather.home oder sensor.…"
                     style="flex:1;min-width:18rem">
              <span class="wp-entity-preview"
                    style="font-size:.85em;color:var(--muted);min-width:8rem"></span>
              <button type="button" class="wp-entity-remove"
                      title="Sensor entfernen" style="margin:0;padding:.2rem .55rem">−</button>
            </div>
          </div>
          <button type="button" class="wp-entity-add"
                  style="margin:0;padding:.25rem .75rem">+ Sensor</button>
        </div>
        <div>
          <button type="submit" style="margin:0"{% if not _active_channels %} disabled{% endif %}>Anlegen</button>
        </div>
      </form>
      {% if not _active_channels %}
        <p style="color:var(--warn,#a60);font-size:.9em;margin:.5rem 0 0">
          Alle Kanäle archiviert — oben einen Kanal wiederherstellen oder neu
          anlegen, um einen neuen Wetter-Auto-Post zu erstellen.
        </p>
      {% endif %}
      <div id="weather-error" style="margin-top:.5rem;color:var(--danger)" hidden></div>
      <p style="font-size:.85em;color:var(--muted);margin:.75rem 0 0">
        Tipp: HA-Entwicklertools → Zustände → nach <code>weather.</code>
        oder <code>sensor.</code> filtern, um die entity_id zu finden.
        Jeder Sensor hat sein eigenes Feld; 2 s nach einer Eingabe holt der
        Browser den aktuellen HA-Wert und zeigt ihn rechts daneben. Der
        Format-Builder fasst alle gefundenen Werte zu einer Channel-Zeile
        zusammen (z.B. <code>🌡18.4 °C · 💧62% · 💨12 km/h</code>).
      </p>
    </div>

    {# ---------- Home-Assistant-Bridge (LLM-Router auf DMs) ---------- #}
    <div class="card" id="ha-bridge-card">
      <h2>Home Assistant Bridge</h2>
      <p style="font-size:.9em;color:var(--muted);margin:0 0 .75rem">
        Wenn aktiviert, beantwortet diese Identität DMs von freigegebenen
        Pubkeys aus dem kuratierten HA-Sensor-Katalog. Der eingehende Text
        geht an ein lokales Ollama-Modell, das passende Entities auswählt;
        die HA-REST-API liest die Werte, und das Modell formuliert eine
        kurze Antwort zurück als DM.
        {% if not weather_ha_enabled %}
          <br><strong style="color:var(--warn,#a60)">HA-Adapter ist nicht
          aktiv</strong> — Settings können bereits gepflegt werden, der
          Antwort-Pfad läuft aber erst, wenn
          <code>homeassistant.enabled=true</code> +
          <code>MESHCORE_HA_TOKEN_FILE</code> gesetzt sind.
        {% endif %}
      </p>

      {% set _bridge = ha_bridge %}
      <form id="ha-bridge-form" onsubmit="return false"
            style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end;margin-bottom:1rem">
        <label style="margin:0;display:inline-flex;gap:.4rem;align-items:center">
          <input type="checkbox" name="enabled"
                 {% if _bridge and _bridge.enabled %}checked{% endif %}>
          aktiv
        </label>
        <label style="margin:0">Ollama-Modell
          <input name="ollama_model" maxlength="128"
                 value="{{ _bridge.ollama_model if _bridge else 'llama3.1:8b' }}">
        </label>
        <label style="margin:0">Max. Entities/Anfrage
          <input name="max_entities_per_query" type="number" min="1" max="5"
                 value="{{ _bridge.max_entities_per_query if _bridge else 3 }}"
                 style="width:5rem">
        </label>
        <label style="margin:0">Limit (Anfragen/min · pro Pubkey)
          <input name="rate_limit_per_min" type="number" min="1" max="60"
                 value="{{ _bridge.rate_limit_per_min if _bridge else 5 }}"
                 style="width:5rem">
        </label>
        <button type="button" id="ha-bridge-save" style="margin:0">Speichern</button>
      </form>
      <div id="ha-bridge-error" style="margin-bottom:.75rem;color:var(--danger)" hidden></div>

      <h3 style="margin-top:1rem">Freigegebene Pubkeys (Whitelist)</h3>
      <p style="font-size:.85em;color:var(--muted);margin:0 0 .5rem">
        Nur DMs von diesen Pubkeys werden vom LLM-Pfad bearbeitet. Alle
        anderen DMs laufen wie gewohnt (Übersetzer/Persistenz). Pubkey
        als 64-Zeichen-Hex (32 Byte Ed25519).
      </p>
      <table id="ha-allowed-table">
        <thead>
          <tr><th>Label</th><th>Pubkey</th><th>Hinzugefügt</th><th></th></tr>
        </thead>
        <tbody>
        {% for p in ha_allowed_pubkeys %}
          <tr data-allowed-id="{{ p.id }}">
            <td>{{ p.label or '' }}</td>
            <td><code title="{{ p.pubkey.hex() }}">{{ p.pubkey.hex()[:16] }}…</code></td>
            <td>{{ p.created_at | localtime }}</td>
            <td>
              <button type="button" class="ha-allowed-delete"
                      style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                löschen
              </button>
            </td>
          </tr>
        {% endfor %}
        {% if not ha_allowed_pubkeys %}
          <tr id="ha-allowed-empty"><td colspan="4" style="color:var(--muted)">Noch kein Pubkey freigegeben.</td></tr>
        {% endif %}
        </tbody>
      </table>
      <form id="ha-allowed-create-form" onsubmit="return false"
            style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end;margin-top:.75rem">
        <label style="margin:0;flex:1;min-width:24rem">Pubkey (hex)
          <input name="pubkey_hex" required maxlength="64" pattern="[0-9a-fA-F]{64}"
                 placeholder="64 Hex-Zeichen" style="font-family:monospace">
        </label>
        <label style="margin:0">Label (optional)
          <input name="label" maxlength="64" placeholder="z.B. mein Phone">
        </label>
        <button type="submit" style="margin:0">Hinzufügen</button>
      </form>

      <h3 style="margin-top:1.25rem">Sensor-Katalog</h3>
      <p style="font-size:.85em;color:var(--muted);margin:0 0 .5rem">
        Diese Entities sieht das LLM beim Routing. Klein halten (≤30): je
        kürzer der Katalog, desto präziser die Auswahl. <code>alias</code>
        ist der menschenlesbare Name im Prompt; <code>hint</code> kann
        Einheit/Wertebereich enthalten.
      </p>
      <div id="ha-entities-list">
      {% for e in ha_exposed_entities %}
        <form class="ha-entity-row" data-entity-id="{{ e.id }}" onsubmit="return false"
              style="border:1px solid var(--border);border-radius:.25rem;padding:.5rem .75rem;margin-bottom:.5rem">
          <div style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end">
            <label style="margin:0;flex:1;min-width:14rem">Entity
              <input value="{{ e.entity_id }}" disabled
                     style="font-family:monospace;width:100%">
            </label>
            <label style="margin:0">Alias
              <input name="alias" maxlength="64" value="{{ e.alias }}">
            </label>
            <label style="margin:0;flex:1;min-width:14rem">Hint
              <input name="hint" maxlength="255" value="{{ e.hint or '' }}"
                     placeholder="z.B. Einheit °C">
            </label>
            <label style="margin:0">Sort
              <input name="sort_order" type="number" value="{{ e.sort_order }}"
                     style="width:4rem">
            </label>
          </div>
          <div style="margin-top:.4rem;display:flex;gap:.5rem;flex-wrap:wrap;align-items:center">
            <button type="button" class="ha-entity-save" style="margin:0;padding:.25rem .75rem">Speichern</button>
            <button type="button" class="ha-entity-delete"
                    style="margin:0;padding:.25rem .75rem;background:var(--danger)">löschen</button>
            <span class="ha-entity-preview" style="font-size:.85em;color:var(--muted)"></span>
          </div>
        </form>
      {% endfor %}
      {% if not ha_exposed_entities %}
        <p id="ha-entities-empty" style="color:var(--muted)">Noch keine Entity im Katalog.</p>
      {% endif %}
      </div>

      <form id="ha-entity-create-form" onsubmit="return false"
            style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end;margin-top:.75rem;border-top:1px dashed var(--border);padding-top:.75rem">
        <label style="margin:0;flex:1;min-width:14rem">Entity-ID
          <input name="entity_id" required maxlength="255"
                 placeholder="sensor.balkon_temperatur"
                 style="font-family:monospace;width:100%">
        </label>
        <label style="margin:0">Alias
          <input name="alias" required maxlength="64" placeholder="Temp Balkon">
        </label>
        <label style="margin:0;flex:1;min-width:14rem">Hint (optional)
          <input name="hint" maxlength="255" placeholder="°C, ~60 s Update">
        </label>
        <button type="submit" style="margin:0">Hinzufügen</button>
        <span id="ha-entity-suggest" style="font-size:.85em;color:var(--muted);flex-basis:100%"></span>
      </form>
      <div id="ha-entity-error" style="margin-top:.5rem;color:var(--danger)" hidden></div>
    </div>

    {# ---------- KI-Agent ---------- #}
    <div class="card" id="ai-agent-card"
         data-min-interval-s="{{ ai_agent_caps.min_interval_s }}"
         data-max-interval-s="{{ ai_agent_caps.max_interval_s }}"
         data-max-prompt-chars="{{ ai_agent_caps.max_prompt_chars }}"
         data-dm-rate-cap="{{ ai_agent_caps.dm_rate_cap_per_hour }}">
      <h2>KI-Agent</h2>
      <p style="font-size:.9em;color:var(--muted);margin:0 0 .75rem">
        Wenn aktiviert, postet diese Identität gemäß Aktivitätsgrad (mit
        Jitter) im gewählten Channel und reagiert auf direkte Erwähnungen
        sowie eingehende DMs. Anti-Loop: andere lokale Companion-
        Identitäten werden hart ignoriert.
        {% if not ai_agent_global_enabled %}
          <br><strong style="color:var(--warn,#a60)">Ollama-Endpoint ist
          nicht konfiguriert</strong> — Settings können bereits gepflegt
          werden, der Loop läuft aber erst, wenn
          <code>ai_agent.enabled=true</code> + eine Ollama-URL gesetzt
          sind (Default aus <code>translation.base_url</code>).
        {% endif %}
      </p>

      {% set _agent = ai_agent %}
      {% set _agent_interval = _agent.interval_s if _agent else 14400 %}
      {% set _agent_prompt = _agent.system_prompt if _agent else '' %}
      {% set _agent_channel = (_agent.channel_id | string) if _agent and _agent.channel_id else '' %}
      <form id="ai-agent-form" onsubmit="return false"
            style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;align-items:start;margin-bottom:1rem">
        <label style="grid-column:1/-1;margin:0;display:inline-flex;gap:.4rem;align-items:center">
          <input type="checkbox" name="enabled"
                 {% if _agent and _agent.enabled %}checked{% endif %}>
          Agent aktiv
        </label>

        <label style="grid-column:1/-1;margin:0">
          System-Prompt (Ziel des Agenten)
          <textarea name="system_prompt"
                    maxlength="{{ ai_agent_caps.max_prompt_chars }}"
                    rows="4" style="width:100%;font-family:inherit"
                    placeholder="Beispiel: Antworte freundlich auf Deutsch, max. 1 Satz. Halte dich an Funkamateur-Themen.">{{ _agent_prompt }}</textarea>
          <span id="ai-agent-prompt-counter" style="font-size:.8em;color:var(--muted)"></span>
        </label>

        <label style="margin:0">Channel
          <select name="channel_id" style="width:100%">
            <option value="">Public (Default)</option>
            {% for ch in channels %}
              <option value="{{ ch.id }}"
                      {% if _agent_channel == (ch.id | string) %}selected{% endif %}>
                {{ ch.name }}
              </option>
            {% endfor %}
          </select>
        </label>

        <label style="margin:0">Aktivität
          <input name="interval_s" type="range"
                 min="{{ ai_agent_caps.min_interval_s }}"
                 max="{{ ai_agent_caps.max_interval_s }}"
                 step="900" value="{{ _agent_interval }}"
                 style="width:100%">
          <span id="ai-agent-interval-label" style="font-size:.85em;color:var(--muted)"></span>
        </label>

        <label style="margin:0;display:inline-flex;gap:.4rem;align-items:center">
          <input type="checkbox" name="respond_on_mention"
                 {% if _agent is none or _agent.respond_on_mention %}checked{% endif %}>
          Auf Erwähnung reagieren
        </label>
        <label style="margin:0;display:inline-flex;gap:.4rem;align-items:center">
          <input type="checkbox" name="respond_to_dms"
                 {% if _agent is none or _agent.respond_to_dms %}checked{% endif %}>
          Auf DMs antworten
        </label>

        <label style="margin:0">DM-Antworten / h / Peer
          <input name="dm_rate_per_hour" type="number" min="0"
                 max="{{ ai_agent_caps.dm_rate_cap_per_hour }}"
                 value="{{ _agent.dm_rate_per_hour if _agent else 6 }}"
                 style="width:5rem">
        </label>
        <label style="margin:0">DM-Verzögerung (Sek.)
          <span style="display:inline-flex;gap:.3rem;align-items:center">
            <input name="dm_min_delay_s" type="number" min="0"
                   value="{{ _agent.dm_min_delay_s if _agent else 10 }}"
                   style="width:4.5rem">
            <span style="color:var(--muted)">–</span>
            <input name="dm_max_delay_s" type="number" min="0"
                   value="{{ _agent.dm_max_delay_s if _agent else 60 }}"
                   style="width:4.5rem">
          </span>
        </label>

        <label style="margin:0">Ollama-Modell
          <input name="ollama_model" maxlength="128"
                 value="{{ _agent.ollama_model if _agent else 'llama3.1:8b' }}"
                 style="width:100%">
        </label>
        <label style="margin:0">Lookback (Min.)
          <input name="lookback_minutes" type="number" min="1" max="1440"
                 value="{{ _agent.lookback_minutes if _agent else 60 }}"
                 style="width:5rem">
        </label>

        <label style="grid-column:1/-1;margin:0">
          Blacklist Sender-Namen (eine pro Zeile)
          <textarea name="blocked_peer_names" rows="2"
                    style="width:100%;font-family:inherit"
                    placeholder="z.B. AnderesBot">{{ _agent.blocked_peer_names if _agent else '' }}</textarea>
        </label>

        <div style="grid-column:1/-1">
          <button type="button" id="ai-agent-save" style="margin:0">Speichern</button>
          <span id="ai-agent-status" style="margin-left:.75rem;font-size:.85em;color:var(--muted)">
            {% if _agent and _agent.next_post_at %}
              nächster Post: {{ _agent.next_post_at | localtime("%d.%m. %H:%M") }}
            {% endif %}
          </span>
        </div>
      </form>
      <div id="ai-agent-error" style="margin-top:.5rem;color:var(--danger)" hidden></div>
    </div>

    {# ---------- API-Tokens ---------- #}
    <div class="card">
      <h2>API-Tokens</h2>
      <p style="font-size:.9em;color:var(--muted);margin:0 0 .75rem">
        Bearer-Tokens für Skripte / Home-Assistant / CLI, die diese
        Identität ansprechen sollen. Ein Token sperrt auf diese Identität.
        Scope <code>read</code> = lesen, <code>write</code> = DM/Channel
        senden, <code>admin</code> = Identitäts-Einstellungen. Token-Anlage
        und Revoke gehen nur über das Web-Login.
      </p>

      <table id="tokens-table">
        <thead>
          <tr><th>Name</th><th>Scopes</th><th>Erstellt</th><th>Zuletzt</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
        {% for t in api_tokens %}
          <tr data-token-id="{{ t.id }}">
            <td>{{ t.name }}</td>
            <td><code>{{ t.scopes }}</code></td>
            <td>{{ t.created_at | localtime }}</td>
            <td>{% if t.last_used_at %}{{ t.last_used_at | localtime }}{% else %}—{% endif %}</td>
            <td class="tok-status">
              {% if t.revoked_at %}<span style="color:var(--danger)">revoked</span>
              {% elif t.expires_at %}<span title="läuft ab">expires {{ t.expires_at | localtime }}</span>
              {% else %}aktiv{% endif %}
            </td>
            <td>
              {% if not t.revoked_at %}
                <button type="button" class="tok-revoke"
                        style="margin:0;padding:.25rem .6rem;background:var(--danger)">
                  revoken
                </button>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        {% if not api_tokens %}
          <tr id="tokens-empty"><td colspan="6" style="color:var(--muted)">Noch kein Token.</td></tr>
        {% endif %}
        </tbody>
      </table>

      <h3 style="margin-top:1rem">Neuen Token erstellen</h3>
      <form id="tokens-create-form" onsubmit="return false"
            style="display:flex;flex-wrap:wrap;gap:.75rem;align-items:flex-end">
        <label style="margin:0">Name
          <input name="name" required maxlength="64" placeholder="z.B. ha-bridge">
        </label>
        <fieldset style="margin:0;padding:.25rem .5rem;border:1px solid var(--border)">
          <legend style="font-size:.85em">Scopes</legend>
          <label style="display:inline-flex;gap:.25rem;align-items:center;margin-right:.75rem">
            <input type="checkbox" name="scope" value="read" checked> read
          </label>
          <label style="display:inline-flex;gap:.25rem;align-items:center;margin-right:.75rem">
            <input type="checkbox" name="scope" value="write"> write
          </label>
          <label style="display:inline-flex;gap:.25rem;align-items:center">
            <input type="checkbox" name="scope" value="admin"> admin
          </label>
        </fieldset>
        <label style="margin:0">Läuft ab (optional, ISO-Datum)
          <input name="expires_at" type="text" placeholder="2027-01-01T00:00:00Z" pattern=".{0}|.{10,}">
        </label>
        <button type="submit" style="margin:0">Erstellen</button>
      </form>

      <div id="token-plaintext-box" hidden
           style="margin-top:1rem;padding:.75rem;border:1px solid var(--warn);background:var(--warn-soft);border-radius:.25rem">
        <strong>Token (wird nur einmal angezeigt — jetzt kopieren!):</strong>
        <div style="display:flex;gap:.5rem;align-items:center;margin-top:.5rem">
          <code id="token-plaintext"
                style="flex:1;user-select:all;word-break:break-all;font-size:1rem"></code>
          <button type="button" id="token-copy-btn" style="margin:0">Kopieren</button>
        </div>
      </div>
      <div id="tokens-error" style="margin-top:.5rem;color:var(--danger)" hidden></div>
    </div>
  </section>

  <script>
    (() => {
      const IDENT = "{{ identity.id }}";
      const tableBody = document.querySelector("#tokens-table tbody");
      const empty = document.getElementById("tokens-empty");
      const form = document.getElementById("tokens-create-form");
      const plainBox = document.getElementById("token-plaintext-box");
      const plainEl = document.getElementById("token-plaintext");
      const errEl = document.getElementById("tokens-error");

      function fmtLocal(iso) {
        if (!iso) return "—";
        try { return new Date(iso).toLocaleString(); } catch { return iso; }
      }

      function showError(msg) {
        errEl.textContent = msg;
        errEl.hidden = false;
      }
      function clearError() { errEl.hidden = true; errEl.textContent = ""; }

      function attachRevoke(btn) {
        btn.addEventListener("click", async () => {
          const tr = btn.closest("tr");
          const tid = tr.dataset.tokenId;
          if (!confirm("Token unwiderruflich revoken?")) return;
          btn.disabled = true;
          try {
            const r = await fetch(`/api/v1/companion/tokens/${tid}/revoke`,
              {method: "POST", credentials: "same-origin"});
            if (!r.ok) { showError(`Revoke fehlgeschlagen: ${r.status}`); btn.disabled = false; return; }
            const data = await r.json();
            tr.querySelector(".tok-status").innerHTML =
              `<span style="color:var(--danger)">revoked</span>`;
            btn.remove();
          } catch (e) {
            showError(String(e));
            btn.disabled = false;
          }
        });
      }
      document.querySelectorAll(".tok-revoke").forEach(attachRevoke);

      // Channel-Archivieren / Wiederherstellen in der Settings-Liste.
      document.querySelectorAll(".ch-archive-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const chId = btn.dataset.chId;
          btn.disabled = true;
          try {
            const r = await fetch(`/api/v1/companion/channels/${chId}/archive`,
              {method: "POST", credentials: "same-origin"});
            if (!r.ok) {
              alert("Archiv-Toggle fehlgeschlagen (HTTP " + r.status + ")");
              btn.disabled = false;
              return;
            }
            // Einfachster Reload — die Tabelle hängt an einer ganzen Reihe
            // serverseitiger Felder (Status-Text, Reihen-Opacity). Lokales
            // Patchen lohnt sich hier nicht.
            location.reload();
          } catch (e) {
            alert("Archiv-Toggle fehlgeschlagen: " + (e && e.message || e));
            btn.disabled = false;
          }
        });
      });

      form.addEventListener("submit", async () => {
        clearError();
        plainBox.hidden = true;
        const fd = new FormData(form);
        const scopes = fd.getAll("scope").join(",");
        if (!scopes) { showError("Mindestens ein Scope wählen."); return; }
        const body = new URLSearchParams();
        body.set("name", fd.get("name"));
        body.set("scopes", scopes);
        const exp = (fd.get("expires_at") || "").trim();
        if (exp) body.set("expires_at", exp);

        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/tokens`,
            {method: "POST", credentials: "same-origin", body});
          if (!r.ok) {
            const t = await r.text();
            showError(`${r.status}: ${t}`); return;
          }
          const t = await r.json();
          plainEl.textContent = t.token;
          plainBox.hidden = false;

          if (empty) empty.remove();
          const tr = document.createElement("tr");
          tr.dataset.tokenId = t.id;
          tr.innerHTML =
            `<td>${t.name.replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]))}</td>` +
            `<td><code>${t.scopes.join(",")}</code></td>` +
            `<td>${fmtLocal(t.created_at)}</td>` +
            `<td>—</td>` +
            `<td class="tok-status">${t.expires_at ? `<span title="läuft ab">expires ${fmtLocal(t.expires_at)}</span>` : "aktiv"}</td>` +
            `<td><button type="button" class="tok-revoke" style="margin:0;padding:.25rem .6rem;background:var(--danger)">revoken</button></td>`;
          tableBody.prepend(tr);
          attachRevoke(tr.querySelector(".tok-revoke"));
          form.reset();
        } catch (e) {
          showError(String(e));
        }
      });

      document.getElementById("token-copy-btn").addEventListener("click", async () => {
        try { await navigator.clipboard.writeText(plainEl.textContent); }
        catch { /* Clipboard kann blockiert sein; user-select:all reicht als Fallback */ }
      });

      // ---------- Wetter-Auto-Posts ----------
      // Pro Post ein eigenes <form>; HA-Sensoren werden je ein Input mit
      // Inline-Preview rechts daneben dargestellt. + Button hängt eine
      // weitere Sensor-Zeile an, − entfernt sie. Beim Speichern werden
      // alle Inputs gesammelt und als CSV in das ``ha_entity_id``-Feld
      // gejoint — das Backend bleibt unverändert.
      const wpErrTop = document.getElementById("weather-error");
      function wpShowError(msg, el) {
        const target = el || wpErrTop;
        if (!target) return;
        target.textContent = msg;
        target.hidden = false;
      }
      function wpClearError(el) {
        const target = el || wpErrTop;
        if (target) { target.hidden = true; target.textContent = ""; }
      }

      const WP_PREVIEW_DEBOUNCE_MS = 2000;
      const WP_ENTITY_TPL = document.getElementById("wp-entity-row-template");

      function wpCollectEntities(formEl) {
        return Array.from(formEl.querySelectorAll(".wp-entity-input"))
          .map(i => i.value.trim())
          .filter(Boolean);
      }

      async function wpPreviewEntity(inputEl, previewSpan) {
        const entityId = inputEl.value.trim();
        if (!entityId) {
          previewSpan.textContent = "";
          previewSpan.style.color = "var(--muted)";
          return;
        }
        previewSpan.textContent = "lade…";
        previewSpan.style.color = "var(--muted)";
        try {
          const r = await fetch(
            `/api/v1/companion/ha/preview?entity_ids=${encodeURIComponent(entityId)}`,
            {credentials: "same-origin"});
          if (!r.ok) {
            previewSpan.textContent = `HTTP ${r.status}`;
            previewSpan.style.color = "var(--danger)";
            return;
          }
          const data = await r.json();
          const item = Array.isArray(data) ? data[0] : null;
          if (!item) {
            previewSpan.textContent = "—";
            previewSpan.style.color = "var(--muted)";
            return;
          }
          if (item.ok) {
            const val = item.formatted ?? item.state;
            previewSpan.textContent = `→ ${val}`;
            previewSpan.style.color = "";
            previewSpan.title = item.friendly_name || "";
          } else {
            previewSpan.textContent = `✗ ${item.error || "Fehler"}`;
            previewSpan.style.color = "var(--danger)";
            previewSpan.title = "";
          }
        } catch (e) {
          previewSpan.textContent = String(e);
          previewSpan.style.color = "var(--danger)";
        }
      }

      function wpWireEntityRow(rowEl, formEl) {
        const input = rowEl.querySelector(".wp-entity-input");
        const preview = rowEl.querySelector(".wp-entity-preview");
        const removeBtn = rowEl.querySelector(".wp-entity-remove");
        let timer = null;
        input.addEventListener("input", () => {
          if (timer) clearTimeout(timer);
          timer = setTimeout(() => {
            timer = null;
            wpPreviewEntity(input, preview);
          }, WP_PREVIEW_DEBOUNCE_MS);
        });
        removeBtn.addEventListener("click", () => {
          const rows = formEl.querySelectorAll(".wp-entity-row");
          if (rows.length <= 1) {
            // Mindestens ein Feld muss bleiben — wir leeren es lieber.
            input.value = "";
            preview.textContent = "";
            input.focus();
            return;
          }
          rowEl.remove();
        });
        // Bei vorgegebenem Wert (Server-Render) direkt eine Vorschau triggern.
        if (input.value.trim()) {
          wpPreviewEntity(input, preview);
        }
      }

      function wpWireEntityList(formEl) {
        formEl.querySelectorAll(".wp-entity-row").forEach((rowEl) => {
          wpWireEntityRow(rowEl, formEl);
        });
        const addBtn = formEl.querySelector(".wp-entity-add");
        if (addBtn) {
          addBtn.addEventListener("click", () => {
            const list = formEl.querySelector(".wp-entities");
            const newRow = WP_ENTITY_TPL.content.firstElementChild.cloneNode(true);
            list.appendChild(newRow);
            wpWireEntityRow(newRow, formEl);
            newRow.querySelector(".wp-entity-input").focus();
          });
        }
      }

      // --- Anlege-Form
      const wpForm = document.getElementById("weather-create-form");
      if (wpForm) {
        wpWireEntityList(wpForm);
        wpForm.querySelector("button[type=submit]").addEventListener("click", async () => {
          wpClearError();
          const entities = wpCollectEntities(wpForm);
          if (!entities.length) {
            wpShowError("Mindestens eine HA-Entity-ID angeben.");
            return;
          }
          const fd = new FormData();
          fd.append("channel_id", wpForm.querySelector("select[name=channel_id]").value);
          fd.append("interval_s", wpForm.querySelector("select[name=interval_s]").value);
          fd.append("location_label", wpForm.querySelector("input[name=location_label]").value);
          fd.append("ha_entity_id", entities.join(","));
          try {
            const r = await fetch(`/api/v1/companion/identities/${IDENT}/weather`,
              {method: "POST", credentials: "same-origin", body: fd});
            if (!r.ok) {
              const detail = await r.text();
              wpShowError(`Anlegen fehlgeschlagen (HTTP ${r.status}): ${detail}`);
              return;
            }
            location.reload();
          } catch (e) {
            wpShowError(String(e));
          }
        });
      }

      // --- Pro-Row Aktionen (Save / Toggle / Delete)
      async function wpPatch(row, fd) {
        const wpId = row.dataset.wpId;
        const errEl = row.querySelector(".wp-error");
        wpClearError(errEl);
        try {
          const r = await fetch(`/api/v1/companion/weather/${wpId}`,
            {method: "PATCH", credentials: "same-origin", body: fd});
          if (!r.ok) {
            const detail = await r.text();
            wpShowError(`Update fehlgeschlagen (HTTP ${r.status}): ${detail}`, errEl);
            return false;
          }
          return true;
        } catch (e) {
          wpShowError(String(e), errEl);
          return false;
        }
      }

      document.querySelectorAll(".wp-row").forEach((row) => {
        const errEl = row.querySelector(".wp-error");
        wpWireEntityList(row);

        row.querySelector(".wp-save-btn").addEventListener("click", async () => {
          const entities = wpCollectEntities(row);
          if (!entities.length) {
            wpShowError("Mindestens eine HA-Entity-ID angeben.", errEl);
            return;
          }
          const fd = new FormData();
          fd.append("channel_id", row.querySelector("select[name=channel_id]").value);
          fd.append("interval_s", row.querySelector("select[name=interval_s]").value);
          fd.append("location_label", row.querySelector("input[name=location_label]").value);
          fd.append("ha_entity_id", entities.join(","));
          const ok = await wpPatch(row, fd);
          if (ok) location.reload();
        });

        const toggleBtn = row.querySelector(".wp-toggle-btn");
        toggleBtn.addEventListener("click", async () => {
          wpClearError(errEl);
          const fd = new FormData();
          fd.append("enabled", toggleBtn.dataset.enabled === "1" ? "false" : "true");
          toggleBtn.disabled = true;
          const ok = await wpPatch(row, fd);
          if (ok) location.reload();
          else toggleBtn.disabled = false;
        });

        row.querySelector(".wp-delete-btn").addEventListener("click", async () => {
          wpClearError(errEl);
          if (!confirm("Wetter-Auto-Post löschen?")) return;
          const wpId = row.dataset.wpId;
          try {
            const r = await fetch(`/api/v1/companion/weather/${wpId}`,
              {method: "DELETE", credentials: "same-origin"});
            if (!r.ok) {
              wpShowError(`Löschen fehlgeschlagen (HTTP ${r.status})`, errEl);
              return;
            }
            location.reload();
          } catch (e) {
            wpShowError(String(e), errEl);
          }
        });
      });
    })();
  </script>

  {# ---------- Home-Assistant-Bridge UI-Logik ---------- #}
  <script>
    (() => {
      const IDENT = "{{ identity.id }}";
      const card = document.getElementById("ha-bridge-card");
      if (!card) return;

      const errBridge = document.getElementById("ha-bridge-error");
      const errAllowed = null;
      const errEntity = document.getElementById("ha-entity-error");

      function showErr(el, msg) {
        if (!el) return;
        el.textContent = msg;
        el.hidden = false;
      }
      function clearErr(el) {
        if (!el) return;
        el.textContent = "";
        el.hidden = true;
      }

      // Bridge-Settings speichern.
      const bridgeForm = document.getElementById("ha-bridge-form");
      document.getElementById("ha-bridge-save").addEventListener("click", async () => {
        clearErr(errBridge);
        const fd = new FormData();
        fd.append("enabled", bridgeForm.querySelector("input[name=enabled]").checked ? "true" : "false");
        fd.append("ollama_model", bridgeForm.querySelector("input[name=ollama_model]").value.trim());
        fd.append("max_entities_per_query", bridgeForm.querySelector("input[name=max_entities_per_query]").value);
        fd.append("rate_limit_per_min", bridgeForm.querySelector("input[name=rate_limit_per_min]").value);
        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/ha_bridge`,
            {method: "PATCH", credentials: "same-origin", body: fd});
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            showErr(errBridge, j.detail || `HTTP ${r.status}`);
            return;
          }
        } catch (e) {
          showErr(errBridge, String(e));
        }
      });

      // Whitelist: Eintrag hinzufügen.
      const allowedForm = document.getElementById("ha-allowed-create-form");
      allowedForm.querySelector("button[type=submit]").addEventListener("click", async () => {
        const pubkey = allowedForm.querySelector("input[name=pubkey_hex]").value.trim();
        const label = allowedForm.querySelector("input[name=label]").value.trim();
        if (!/^[0-9a-fA-F]{64}$/.test(pubkey)) {
          alert("Pubkey muss 64 Hex-Zeichen sein");
          return;
        }
        const fd = new FormData();
        fd.append("pubkey_hex", pubkey);
        if (label) fd.append("label", label);
        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/ha_bridge/allowed`,
            {method: "POST", credentials: "same-origin", body: fd});
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            alert(j.detail || `HTTP ${r.status}`);
            return;
          }
          location.reload();
        } catch (e) {
          alert(String(e));
        }
      });

      // Whitelist: Eintrag löschen.
      document.querySelectorAll(".ha-allowed-delete").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (!confirm("Pubkey von Whitelist entfernen?")) return;
          const id = btn.closest("tr").dataset.allowedId;
          try {
            const r = await fetch(`/api/v1/companion/ha_bridge/allowed/${id}`,
              {method: "DELETE", credentials: "same-origin"});
            if (!r.ok) {
              alert(`Löschen fehlgeschlagen (HTTP ${r.status})`);
              return;
            }
            location.reload();
          } catch (e) {
            alert(String(e));
          }
        });
      });

      // Entity-Katalog: Live-Preview (Friendly-Name) während des Tippens.
      const entCreateForm = document.getElementById("ha-entity-create-form");
      const entIdInput = entCreateForm.querySelector("input[name=entity_id]");
      const entAliasInput = entCreateForm.querySelector("input[name=alias]");
      const entSuggest = document.getElementById("ha-entity-suggest");
      let entSuggestTimer = null;
      entIdInput.addEventListener("input", () => {
        const v = entIdInput.value.trim();
        if (entSuggestTimer) clearTimeout(entSuggestTimer);
        entSuggest.textContent = "";
        if (!v) return;
        entSuggestTimer = setTimeout(async () => {
          try {
            const r = await fetch(`/api/v1/companion/ha/preview?entity_ids=${encodeURIComponent(v)}`,
              {credentials: "same-origin"});
            if (!r.ok) {
              entSuggest.textContent = `Preview-HTTP ${r.status}`;
              return;
            }
            const arr = await r.json();
            const item = Array.isArray(arr) ? arr[0] : null;
            if (!item || !item.ok) {
              entSuggest.textContent = item && item.error
                ? `⚠ ${item.error}` : "⚠ keine Daten";
              return;
            }
            entSuggest.textContent = `${item.friendly_name || "(kein friendly_name)"} · ${item.formatted}`;
            // Alias-Suggest, wenn Feld leer.
            if (!entAliasInput.value && item.friendly_name) {
              entAliasInput.placeholder = item.friendly_name;
            }
          } catch (e) {
            entSuggest.textContent = String(e);
          }
        }, 600);
      });

      // Entity hinzufügen.
      entCreateForm.querySelector("button[type=submit]").addEventListener("click", async () => {
        clearErr(errEntity);
        const fd = new FormData();
        fd.append("entity_id", entIdInput.value.trim());
        // Alias-Fallback auf den Suggest, falls leer.
        const aliasVal = entAliasInput.value.trim()
          || (entAliasInput.placeholder || "").trim();
        fd.append("alias", aliasVal);
        const hint = entCreateForm.querySelector("input[name=hint]").value.trim();
        if (hint) fd.append("hint", hint);
        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/ha_bridge/entities`,
            {method: "POST", credentials: "same-origin", body: fd});
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            showErr(errEntity, j.detail || `HTTP ${r.status}`);
            return;
          }
          location.reload();
        } catch (e) {
          showErr(errEntity, String(e));
        }
      });

      // Entity-Row: Speichern + Löschen.
      document.querySelectorAll(".ha-entity-row").forEach(row => {
        const id = row.dataset.entityId;
        const preview = row.querySelector(".ha-entity-preview");
        const entityId = row.querySelector("input[disabled]").value;

        // Live-Preview einmal beim Laden.
        (async () => {
          try {
            const r = await fetch(`/api/v1/companion/ha/preview?entity_ids=${encodeURIComponent(entityId)}`,
              {credentials: "same-origin"});
            if (!r.ok) return;
            const arr = await r.json();
            const item = Array.isArray(arr) ? arr[0] : null;
            if (item && item.ok) preview.textContent = `→ ${item.formatted}`;
            else if (item) preview.textContent = `⚠ ${item.error || "no data"}`;
          } catch (_e) { /* ignore */ }
        })();

        row.querySelector(".ha-entity-save").addEventListener("click", async () => {
          const fd = new FormData();
          fd.append("alias", row.querySelector("input[name=alias]").value);
          fd.append("hint", row.querySelector("input[name=hint]").value);
          fd.append("sort_order", row.querySelector("input[name=sort_order]").value);
          try {
            const r = await fetch(`/api/v1/companion/ha_bridge/entities/${id}`,
              {method: "PATCH", credentials: "same-origin", body: fd});
            if (!r.ok) {
              const j = await r.json().catch(() => ({}));
              alert(j.detail || `HTTP ${r.status}`);
              return;
            }
          } catch (e) {
            alert(String(e));
          }
        });
        row.querySelector(".ha-entity-delete").addEventListener("click", async () => {
          if (!confirm(`Entity ${entityId} aus Katalog entfernen?`)) return;
          try {
            const r = await fetch(`/api/v1/companion/ha_bridge/entities/${id}`,
              {method: "DELETE", credentials: "same-origin"});
            if (!r.ok) {
              alert(`Löschen fehlgeschlagen (HTTP ${r.status})`);
              return;
            }
            location.reload();
          } catch (e) {
            alert(String(e));
          }
        });
      });
    })();
  </script>

  <script>
    // KI-Agent: Save + Slider-Label + Char-Counter + Inline-SSE-Log
    (() => {
      const IDENT = "{{ identity.id }}";
      const card = document.getElementById("ai-agent-card");
      if (!card) return;
      const form = document.getElementById("ai-agent-form");
      const err = document.getElementById("ai-agent-error");
      const status = document.getElementById("ai-agent-status");

      const slider = form.querySelector("input[name=interval_s]");
      const label = document.getElementById("ai-agent-interval-label");
      const promptArea = form.querySelector("textarea[name=system_prompt]");
      const promptCounter = document.getElementById("ai-agent-prompt-counter");
      const maxPromptChars = parseInt(card.dataset.maxPromptChars, 10) || 2000;

      function formatInterval(seconds) {
        const s = parseInt(seconds, 10);
        if (!isFinite(s) || s < 60) return `${s} s`;
        if (s < 3600) return `≈ alle ${Math.round(s / 60)} Min.`;
        const hours = s / 3600;
        if (hours < 1.5) return "≈ 1× pro Stunde";
        if (hours < 24) return `≈ alle ${hours.toFixed(hours < 6 ? 1 : 0)} Std.`;
        if (hours < 36) return "≈ 1× pro Tag";
        const days = (hours / 24).toFixed(1);
        return `≈ alle ${days} Tage`;
      }

      function updateLabel() {
        label.textContent = formatInterval(slider.value);
      }
      slider.addEventListener("input", updateLabel);
      updateLabel();

      function updateCounter() {
        const used = promptArea.value.length;
        promptCounter.textContent = `${used} / ${maxPromptChars} Zeichen`;
      }
      promptArea.addEventListener("input", updateCounter);
      updateCounter();

      function showErr(msg) {
        err.textContent = msg;
        err.hidden = false;
      }
      function clearErr() {
        err.textContent = "";
        err.hidden = true;
      }

      document.getElementById("ai-agent-save").addEventListener("click", async () => {
        clearErr();
        const fd = new FormData();
        fd.append("enabled", form.querySelector("input[name=enabled]").checked ? "true" : "false");
        fd.append("system_prompt", form.querySelector("textarea[name=system_prompt]").value);
        fd.append("interval_s", slider.value);
        fd.append("channel_id", form.querySelector("select[name=channel_id]").value);
        fd.append("respond_on_mention", form.querySelector("input[name=respond_on_mention]").checked ? "true" : "false");
        fd.append("respond_to_dms", form.querySelector("input[name=respond_to_dms]").checked ? "true" : "false");
        fd.append("dm_rate_per_hour", form.querySelector("input[name=dm_rate_per_hour]").value);
        fd.append("dm_min_delay_s", form.querySelector("input[name=dm_min_delay_s]").value);
        fd.append("dm_max_delay_s", form.querySelector("input[name=dm_max_delay_s]").value);
        fd.append("blocked_peer_names", form.querySelector("textarea[name=blocked_peer_names]").value);
        fd.append("ollama_model", form.querySelector("input[name=ollama_model]").value.trim());
        fd.append("lookback_minutes", form.querySelector("input[name=lookback_minutes]").value);
        try {
          const r = await fetch(`/api/v1/companion/identities/${IDENT}/ai_agent`,
            {method: "PATCH", credentials: "same-origin", body: fd});
          if (!r.ok) {
            const j = await r.json().catch(() => ({}));
            showErr(j.detail || `HTTP ${r.status}`);
            return;
          }
          const j = await r.json();
          if (j.next_post_at) {
            const dt = new Date(j.next_post_at);
            status.textContent = `nächster Post: ${dt.toLocaleString()}`;
          } else {
            status.textContent = "gespeichert";
          }
        } catch (e) {
          showErr(String(e));
        }
      });
    })();
  </script>

  <script id="companion-bootstrap" type="application/json">
    {"identityId": "{{ identity.id }}", "identityName": {{ identity.name | tojson }}, "atTargets": {{ at_targets | tojson }}}
  </script>
  <script src="/static/companion.js?v={{ asset_version }}" defer></script>
