def cmd_login(c: Client, args: argparse.Namespace) -> int:
    ident = _resolve_identity(c, args.identity)
    peer_hex, name = _resolve_peer(c, ident["id"], args.peer)
    target = name or _short_hex(peer_hex, 12)
    if not args.json:
        print(
            f"🔑 Login angefragt an {target} (Antwort kommt asynchron — ggf. tail nutzen)",
            flush=True,
        )
    j = c.request(
        f"/api/v1/companion/identities/{ident['id']}/contacts/{peer_hex}/login",
        method="POST",
        data={"password": args.password or ""},
    )
    if args.json:
        _print(j, args)
        return 0
    if not j.get("ok"):
        return 1
    if args.wait <= 0:
        return 0
    return _poll_login_state(c, ident["id"], peer_hex, target, args.wait, args)


def _poll_login_state(
    c: Client,
    identity_id: str,
    peer_hex: str,
    target: str,
    timeout_s: float,
    args: argparse.Namespace,
) -> int:
    deadline = time.monotonic() + timeout_s
    while time.monotonic() < deadline:
        time.sleep(1.0)
        try:
            j = c.request(
                f"/api/v1/companion/identities/{identity_id}/contacts/{peer_hex}/login-state",
                quiet=True,
            )
        except (HTTPError, URLError):
            # 502/404/Timeout während Polling sind erwartbar (Container-
            # Restart, Traefik-Hänger). Wir bleiben dran.
            continue
        if j.get("logged_in"):
            role = "admin" if j.get("is_admin") else "guest"
            print(
                f"✓ Login OK · {target} · Rolle {role} · "
                f"Permissions 0x{int(j.get('permissions', 0)):02x} · "
                f"gültig bis {_fmt_ts(j.get('expires_at'))}"
            )
            return 0
    print(f"⏱ kein Login-OK innerhalb {int(timeout_s)}s — vermutlich verloren auf LoRa")
    return 2


def cmd_login_state(c: Client, args: argparse.Namespace) -> int:
    ident = _resolve_identity(c, args.identity)
    peer_hex, name = _resolve_peer(c, ident["id"], args.peer)
    j = c.request(
        f"/api/v1/companion/identities/{ident['id']}/contacts/{peer_hex}/login-state"
    )
    target = name or _short_hex(peer_hex, 12)
    logged_in = bool(j.get("logged_in"))
    if args.json:
        _print(j, args)
    elif not logged_in:
        print(f"{target}: nicht eingeloggt")
    else:
        role = "admin" if j.get("is_admin") else "guest"
        print(
            f"{target}: eingeloggt ({role}, perms 0x{int(j.get('permissions', 0)):02x}) "
            f"bis {_fmt_ts(j.get('expires_at'))}"
        )
    return 0 if logged_in else 1


