def cmd_search(c: Client, args: argparse.Namespace) -> int:
    ident = _resolve_identity(c, args.identity)
    qs = urlencode({"q": args.query, "limit": args.n})
    j = c.request(f"/api/v1/companion/identities/{ident['id']}/search?{qs}")
    if args.json:
        _print(j, args)
        return 0
    hits = j.get("hits") or j.get("results") or []
    if not hits:
        # Schema kann je nach Server-Version variieren — Fallback: rohes JSON.
        _print(j, args)
        return 0
    for h in hits:
        snippet = (h.get("snippet") or "").replace("\n", " ")
        ctx = (
            f"#{h.get('channel_name')}"
            if h.get("channel_name")
            else (h.get("peer_name") or _short_hex(h.get("peer_pubkey")))
        )
        print(f"{_fmt_ts(h.get('ts'))} [{ctx}] {snippet}")
    return 0


def cmd_auth_login(c: Client, args: argparse.Namespace) -> int:
    """Erzwingt einen Email/Passwort-Login und persistiert den Cookie."""
    email = args.email or input("email: ").strip()
    password = args.password or getpass.getpass("password: ")
    try:
        c.login(email, password)
    except HTTPError as e:
        sys.stderr.write(f"Login fehlgeschlagen: HTTP {e.code}\n")
        return 2
    if not c.has_session():
        sys.stderr.write("Login lieferte keine Session — falsche Credentials?\n")
        return 2
    c.save_session()
    info = c.whoami()
    n = info["identities"] if info else 0
    print(
        f"Login OK · Session gespeichert in {c._session_file} · "  # noqa: SLF001
        f"{n} Identitäten sichtbar"
    )
    return 0


def cmd_auth_logout(c: Client, args: argparse.Namespace) -> int:
    """Löscht die lokale Cookie-Datei. Eine serverseitige Revocation findet
    nicht statt (Endpoint /logout würde die Session in der DB löschen, ist
    hier aber nicht zwingend — die Cookie-Datei reicht für lokale Hygiene)."""
    path = c._session_file  # noqa: SLF001
    c.clear_session()
    if args.json:
        _print({"cleared": True, "path": str(path) if path else None}, args)
    else:
        print(f"Session-Datei gelöscht: {path}")
    return 0


def cmd_auth_whoami(c: Client, args: argparse.Namespace) -> int:
    info = c.whoami()
    if info is None:
        if args.json:
            _print({"authenticated": False}, args)
        else:
            print("nicht eingeloggt (Session fehlt oder abgelaufen)")
        return 1
    if args.json:
        _print({"authenticated": True, **info}, args)
    else:
        print(f"eingeloggt · {info['identities']} Identitäten sichtbar")
    return 0


def cmd_tail(c: Client, args: argparse.Namespace) -> int:
    ident = _resolve_identity(c, args.identity)
    path = f"/api/v1/companion/identities/{quote(ident['id'])}/stream"
    # Line-buffered stdout, damit Pipes/timeout sofort sehen, was eintrudelt.
    try:
        sys.stdout.reconfigure(line_buffering=True)  # type: ignore[attr-defined]
    except (AttributeError, OSError):
        pass
    print(f"# Stream {ident['name']} ({ident['id']}) — Ctrl-C zum Beenden", flush=True)
    try:
        resp = c.open_stream(path)
    except HTTPError as e:
        sys.stderr.write(f"Stream-Fehler: HTTP {e.code}\n")
        return 2
    try:
        for raw in resp:
            line = raw.decode("utf-8", errors="replace").rstrip("\n")
            if not line or line.startswith(":"):
                continue
            if line.startswith("data: "):
                payload = line[6:]
                try:
                    evt = json.loads(payload)
                except json.JSONDecodeError:
                    print(line, flush=True)
                    continue
                if args.json:
                    print(json.dumps(evt, ensure_ascii=False), flush=True)
                    continue
                t = evt.get("type", "?")
                ts = _fmt_ts(evt.get("ts"))
                txt = (evt.get("text") or "").replace("\n", " ")
                peer = evt.get("peer_name") or _short_hex(
                    evt.get("peer_pubkey_hex"), 8
                )
                ch = evt.get("channel_name")
                ctx = f"#{ch}" if ch else peer
                print(f"{ts} [{t}] {ctx}: {txt}", flush=True)
    except KeyboardInterrupt:
        print()
        return 0
    finally:
        resp.close()
    return 0


# ---------- main ----------


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("--url", default=os.environ.get("MESHCORE_CTL_URL", DEFAULT_URL))
    p.add_argument("--email", default=os.environ.get("MESHCORE_CTL_EMAIL"))
    p.add_argument(
        "--password",
        default=os.environ.get("MESHCORE_CTL_PASSWORD"),
        help="Default: prompt oder MESHCORE_CTL_PASSWORD",
    )
    p.add_argument(
        "--session-file",
        default=os.environ.get("MESHCORE_SESSION_FILE"),
        help="Cookie-Jar-Pfad (Default: ~/.config/spiegel-companion/session)",
    )
    # `--json` an jedem Subcommand via parents=[common]; zusätzlich auch vor
    # dem Subcommand erlaubt. `default=SUPPRESS` verhindert, dass der
    # Subparser den vorab gesetzten Wert wieder auf False überschreibt.
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument(
        "--json", action="store_true", default=argparse.SUPPRESS, help="JSON-Ausgabe"
    )
    p.add_argument(
        "--json", action="store_true", default=False, help=argparse.SUPPRESS
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    ap = sub.add_parser("auth", help="Session-Verwaltung")
    ap_sub = ap.add_subparsers(dest="auth_cmd", required=True)
    ap_sub.add_parser("login", parents=[common]).set_defaults(func=cmd_auth_login)
    ap_sub.add_parser("logout", parents=[common]).set_defaults(func=cmd_auth_logout)
    ap_sub.add_parser("whoami", parents=[common]).set_defaults(func=cmd_auth_whoami)

    sub.add_parser("identities", parents=[common]).set_defaults(func=cmd_identities)

    sp = sub.add_parser("contacts", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("-n", type=int, default=50)
    sp.set_defaults(func=cmd_contacts)

    sp = sub.add_parser("threads", parents=[common])
    sp.add_argument("identity")
    sp.set_defaults(func=cmd_threads)

    sp = sub.add_parser("dms", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.add_argument("-n", type=int, default=30)
    sp.set_defaults(func=cmd_dms)

    sp = sub.add_parser("ch-msgs", parents=[common], help="Channel-Verlauf")
    sp.add_argument("identity")
    sp.add_argument("channel")
    sp.add_argument("-n", type=int, default=30)
    sp.set_defaults(func=cmd_channel_msgs)

    sp = sub.add_parser("send-dm", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.add_argument("text")
    sp.set_defaults(func=cmd_send_dm)

    sp = sub.add_parser("send-ch", parents=[common], help="Nachricht in Channel senden")
    sp.add_argument("identity")
    sp.add_argument("channel")
    sp.add_argument("text")
    sp.set_defaults(func=cmd_send_channel)

    sp = sub.add_parser("login", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.add_argument("-p", "--password", default="", help="leer = Guest-Login")
    sp.add_argument(
        "--wait",
        type=float,
        default=12.0,
        help="Sekunden auf Login-OK pollen (0 = nicht warten)",
    )
    sp.set_defaults(func=cmd_login)

    sp = sub.add_parser("login-state", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.set_defaults(func=cmd_login_state)

    sp = sub.add_parser("status", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("telemetry", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("peer")
    sp.set_defaults(func=cmd_telemetry)

    sp = sub.add_parser("advert", parents=[common])
    sp.add_argument("identity")
    sp.set_defaults(func=cmd_advert)

    sp = sub.add_parser("search", parents=[common])
    sp.add_argument("identity")
    sp.add_argument("query")
    sp.add_argument("-n", type=int, default=30)
    sp.set_defaults(func=cmd_search)

    sp = sub.add_parser("tail", parents=[common], help="SSE-Stream (Live-Events)")
    sp.add_argument("identity")
    sp.set_defaults(func=cmd_tail)

    args = p.parse_args()

    session_path = Path(args.session_file) if args.session_file else _default_session_path()
    c = Client(args.url, session_file=session_path)

    # Direkt-Cookie via ENV überstimmt alles andere — z.B. für CI.
    env_session = os.environ.get("MESHCORE_SESSION")
    if env_session:
        c.inject_session_cookie(env_session.strip())

    is_auth_cmd = args.cmd == "auth"

    # auth login wickelt sein Auth-Handling selbst ab; logout/whoami brauchen
    # nur den Cookie-Jar. Alle anderen Commands wollen eine valide Session.
    if not is_auth_cmd:
        if not c.has_session():
            email = args.email or input("email: ").strip()
            password = args.password or getpass.getpass("password: ")
            try:
                c.login(email, password)
            except HTTPError as e:
                sys.stderr.write(f"Login fehlgeschlagen: HTTP {e.code}\n")
                return 2
            if not c.has_session():
                sys.stderr.write("Login lieferte keine Session.\n")
                return 2
            c.save_session()
    try:
        return args.func(c, args)
    except HTTPError as e:
        if e.code == 401 and not is_auth_cmd:
            sys.stderr.write(
                "Session abgelaufen oder ungültig. Bitte 'auth login' erneut ausführen.\n"
            )
            c.clear_session()
            return 2
        return 2


if __name__ == "__main__":
    sys.exit(main())
